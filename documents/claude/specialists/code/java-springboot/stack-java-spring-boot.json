{
  "$comment": "Java Spring Boot stack — merged from stack-definitions + stacks + architecture-definitions",
  "name": "Java Spring Boot",
  "language": "java",
  "framework": "spring-boot",
  "version": {
    "java": "21",
    "springBoot": "3.4.x",
    "springCloud": "2024.0.0"
  },
  "extensions": [".java"],

  "searchKeywords": {
    "backend": ["Java", "Spring Boot", "Spring Data"],
    "patterns": ["Clean Architecture Java", "Repository Pattern Spring", "Service Layer"],
    "libraries": ["MapStruct", "Resilience4j", "Spring Security"],
    "testing": ["JUnit", "Mockito", "TestContainers"],
    "package": ["Maven", "Gradle", "pom.xml"],
    "exclude": ["C#", "ASP.NET", "NuGet", "Entity Framework", ".NET"]
  },

  "parsing": {
    "parser": "java-parser",
    "extractor": "spring-extractor",
    "patterns": {
      "controller": {
        "markers": ["RestController", "Controller"],
        "nameSuffix": ["Resource", "Controller", "Api"],
        "nodeType": "Controller"
      },
      "service": {
        "markers": ["Service", "Component"],
        "nameSuffix": ["Service", "ServiceImpl", "Handler"],
        "nodeType": "Service"
      },
      "repository": {
        "markers": ["Repository"],
        "nameSuffix": ["Repository", "Repo", "Dao"],
        "nodeType": "Repository",
        "interfaces": ["JpaRepository", "CrudRepository", "R2dbcRepository"]
      },
      "entity": {
        "markers": ["Entity", "Table"],
        "nodeType": "Entity"
      },
      "dto": {
        "nameSuffix": ["DTO", "Dto", "Request", "Response", "Payload"],
        "nodeType": "Class"
      },
      "mapper": {
        "nameSuffix": ["Mapper", "Converter"],
        "interfaces": ["Mapper"],
        "nodeType": "Component"
      },
      "config": {
        "markers": ["Configuration", "ConfigurationProperties"],
        "nameSuffix": ["Config", "Configuration", "Properties"],
        "nodeType": "Component"
      }
    },
    "annotations": {
      "http": {
        "GET": ["GetMapping", "RequestMapping(method=GET)"],
        "POST": ["PostMapping", "RequestMapping(method=POST)"],
        "PUT": ["PutMapping", "RequestMapping(method=PUT)"],
        "DELETE": ["DeleteMapping", "RequestMapping(method=DELETE)"],
        "PATCH": ["PatchMapping", "RequestMapping(method=PATCH)"]
      },
      "injection": ["Autowired", "Inject", "Resource", "Value"],
      "validation": ["Valid", "NotNull", "NotBlank", "Size", "Pattern", "Email"],
      "transaction": ["Transactional", "Modifying"],
      "security": ["PreAuthorize", "Secured", "RolesAllowed"]
    },
    "packages": {
      "controller": "*.web.*",
      "service": "*.service.*",
      "repository": "*.repository.*",
      "entity": "*.domain.*",
      "dto": "*.dto.*",
      "config": "*.config.*"
    }
  },

  "architecture": {
    "supportedArchitectures": ["clean-architecture", "hexagonal", "layered", "ddd", "cqrs", "modular-monolith"],
    "defaultArchitecture": null,
    "layerConstraintOverrides": {
      "clean-architecture": {
        "application": {
          "additionalMarkers": ["@Slf4j"],
          "additionalResponsibilities": ["Reactive stream handling"]
        },
        "infrastructure": {
          "requiredMarkers": ["@Repository"],
          "additionalPatterns": ["extends ReactiveCrudRepository"]
        }
      }
    },
    "autoDetection": {
      "clean-architecture": {
        "requiredDirs": ["domain", "application", "infrastructure"],
        "alternativeDirs": ["presentation", "usecase"],
        "indicators": ["@Service", "@Repository", "@RestController"],
        "confidence": 0.8
      },
      "hexagonal": {
        "requiredDirs": ["domain", "ports", "adapters"],
        "alternativeDirs": ["core", "application/ports", "infrastructure/adapters"],
        "indicators": ["@Port", "@Adapter", "@UseCase"],
        "confidence": 0.85
      },
      "layered": {
        "requiredDirs": ["controller", "service", "dao"],
        "alternativeDirs": ["presentation", "business", "data"],
        "indicators": ["@Controller", "@Service", "@Repository"],
        "confidence": 0.75
      },
      "ddd": {
        "requiredDirs": ["domain/model", "domain/repository", "application", "infrastructure"],
        "indicators": ["@AggregateRoot", "@ValueObject", "@DomainEvent"],
        "confidence": 0.85
      },
      "modular-monolith": {
        "pattern": "modules/*/{domain,application,infrastructure}",
        "indicators": ["@Module"],
        "confidence": 0.8
      }
    },
    "layerMappings": {
      "clean-architecture": {
        "domain": {
          "pathPatterns": ["**/domain/**", "**/model/**", "**/entity/**"],
          "markers": ["@Entity", "@MappedSuperclass", "@Embeddable", "@ValueObject"],
          "baseClasses": ["AbstractAuditingEntity"],
          "stereotype": "DomainEntity"
        },
        "application": {
          "pathPatterns": ["**/service/**", "**/application/**", "**/usecase/**"],
          "markers": ["@Service", "@Transactional", "@UseCase"],
          "nameSuffix": ["Service", "ServiceImpl", "UseCase", "UseCaseImpl"],
          "stereotype": "ApplicationService"
        },
        "infrastructure": {
          "pathPatterns": ["**/repository/**", "**/infrastructure/**", "**/config/**"],
          "markers": ["@Repository", "@Configuration", "@Component"],
          "interfaces": ["ReactiveCrudRepository", "JpaRepository", "R2dbcRepository"],
          "nameSuffix": ["Repository", "RepositoryImpl", "Gateway", "Client"],
          "stereotype": "InfrastructureComponent"
        },
        "presentation": {
          "pathPatterns": ["**/web/rest/**", "**/controller/**", "**/rest/**", "**/api/**"],
          "markers": ["@RestController", "@Controller", "@RequestMapping"],
          "nameSuffix": ["Resource", "Controller", "Api", "Endpoint"],
          "stereotype": "PresentationController"
        }
      },
      "hexagonal": {
        "domain": {
          "pathPatterns": ["**/domain/**", "**/core/**"],
          "markers": ["@Entity", "@AggregateRoot"],
          "stereotype": "DomainEntity"
        },
        "ports": {
          "pathPatterns": ["**/ports/**", "**/application/ports/**"],
          "markers": ["@Port"],
          "nameSuffix": ["Port", "UseCase", "Gateway"],
          "stereotype": "Port"
        },
        "adapters": {
          "pathPatterns": ["**/adapters/**", "**/infrastructure/**"],
          "markers": ["@Adapter"],
          "nameSuffix": ["Adapter", "Repository", "Client"],
          "stereotype": "Adapter"
        }
      },
      "layered": {
        "presentation": {
          "pathPatterns": ["**/controller/**", "**/web/**"],
          "markers": ["@Controller", "@RestController"],
          "stereotype": "Controller"
        },
        "business": {
          "pathPatterns": ["**/service/**", "**/business/**"],
          "markers": ["@Service"],
          "stereotype": "Service"
        },
        "data": {
          "pathPatterns": ["**/dao/**", "**/repository/**", "**/data/**"],
          "markers": ["@Repository"],
          "stereotype": "DataAccessObject"
        }
      }
    },
    "databasePatterns": {
      "r2dbc": {
        "detection": {
          "interfaces": ["ReactiveCrudRepository", "R2dbcRepository"],
          "imports": ["io.r2dbc", "reactor.core"],
          "returnTypes": ["Mono", "Flux"]
        },
        "technology": "Spring Data R2DBC",
        "reactive": true,
        "customPatterns": {
          "customRepository": "*RepositoryInternal + *RepositoryInternalImpl",
          "queryBuilder": "ReactiveQueryBuilder",
          "sqlHelper": "*SqlHelper"
        }
      },
      "jpa": {
        "detection": {
          "interfaces": ["JpaRepository", "CrudRepository", "PagingAndSortingRepository"],
          "imports": ["javax.persistence", "jakarta.persistence"],
          "annotations": ["@Entity", "@Table", "@Id"]
        },
        "technology": "Spring Data JPA / Hibernate",
        "reactive": false
      },
      "jdbc": {
        "detection": {
          "classes": ["JdbcTemplate", "NamedParameterJdbcTemplate"],
          "imports": ["org.springframework.jdbc"]
        },
        "technology": "Spring JDBC",
        "reactive": false
      },
      "mybatis": {
        "detection": {
          "interfaces": ["@Mapper"],
          "files": ["*Mapper.xml"],
          "imports": ["org.mybatis"]
        },
        "technology": "MyBatis",
        "reactive": false
      }
    }
  },

  "variants": {
    "standard": {
      "name": "Standard JPA Stack",
      "description": "Spring Data JPA with REST controllers",
      "detection": {
        "files": ["pom.xml", "build.gradle", "build.gradle.kts"],
        "requires": ["spring-boot-starter-data-jpa"],
        "rejects": ["spring-boot-starter-webflux", "spring-modulith"],
        "priority": 3
      },
      "validation": {
        "files": ["pom.xml", "build.gradle", "build.gradle.kts"],
        "mustHave": ["spring-boot-starter-data-jpa"]
      },
      "patterns": {
        "use_jpa": true,
        "use_spring_data": true,
        "use_rest_controller": true,
        "use_jdbc_template": false,
        "use_webflux": false,
        "use_r2dbc": false
      },
      "specialists": {
        "java_language": ["java-fundamentals-specialist", "java-concurrency-specialist", "java-code-quality-specialist", "java-design-patterns-specialist"],
        "spring_core": ["spring-boot-configuration-specialist", "spring-aop-specialist"],
        "architecture": ["architecture-patterns-specialist"],
        "standard": ["java-domain-specialist", "java-service-specialist", "java-repository-specialist", "java-controller-specialist", "java-dto-specialist", "java-validation-specialist", "java-exception-specialist"],
        "api": ["api-design-governance-specialist", "graphql-spring-specialist"],
        "data_access": ["jpa-hibernate-specialist", "transaction-management-specialist"],
        "integration": ["http-client-patterns-specialist", "file-handling-specialist"],
        "security": ["java-security-specialist", "security-advanced-specialist"],
        "quality": ["java-testing-specialist", "testing-advanced-specialist"],
        "observability": ["custom-observability-specialist"],
        "patterns": ["distributed-patterns-specialist"],
        "analytics_ai": ["bi-analytics-specialist", "nl-to-sql-specialist", "llm-integration-specialist"],
        "infrastructure": ["maven-advanced-specialist", "ci-cd-patterns-specialist", "kubernetes-spring-specialist"]
      },
      "specialistDir": "java-springboot",
      "kb_path": {
        "backend": ".claude/utils/knowledge-base/backend-kb.json",
        "database": ".claude/utils/knowledge-base/database-kb.json"
      }
    },
    "clean-modulith": {
      "name": "Clean-Modulith Stack (Blocking + Virtual Threads)",
      "description": "Spring Modulith with Spring Data JDBC, JdbcClient, RestClient — blocking on virtual threads, no JPA/WebFlux",
      "detection": {
        "files": ["pom.xml", "build.gradle", "build.gradle.kts"],
        "requires": ["spring-boot-starter-data-jdbc", "spring-modulith"],
        "rejects": ["spring-boot-starter-webflux"],
        "priority": 2
      },
      "validation": {
        "files": ["pom.xml", "build.gradle", "build.gradle.kts"],
        "mustNotHave": ["spring-boot-starter-data-jpa", "spring-boot-starter-webflux"]
      },
      "patterns": {
        "use_jpa": false,
        "use_spring_data": true,
        "use_spring_data_jdbc": true,
        "use_jdbc_client": true,
        "use_jdbc_template": false,
        "use_webflux": false,
        "use_r2dbc": false,
        "use_rest_controller": true,
        "use_rest_client": true,
        "use_virtual_threads": true,
        "use_spring_modulith": true,
        "use_kafka": true,
        "use_redis": true,
        "use_elasticsearch": true,
        "use_multitenancy": true,
        "use_clean_architecture": true,
        "use_mapstruct": true,
        "use_resilience4j": true,
        "use_s3": true,
        "use_jobrunr": true
      },
      "specialists": {
        "java_language": ["java-fundamentals-specialist", "java-concurrency-specialist", "java-code-quality-specialist", "java-design-patterns-specialist"],
        "spring_core": ["spring-boot-configuration-specialist", "spring-aop-specialist"],
        "architecture": ["backend-clean-architecture-specialist", "architecture-patterns-specialist"],
        "clean_modulith": ["spring-data-jdbc-specialist", "jdbcclient-specialist", "spring-modulith-specialist", "restclient-specialist", "usecase-port-specialist"],
        "standard": ["java-controller-specialist", "java-dto-specialist", "java-validation-specialist", "java-exception-specialist", "java-mapper-specialist", "java-di-specialist"],
        "crud_patterns": ["crud-service-base-specialist", "search-criteria-specialist", "pagination-specialist", "viewmodel-specialist"],
        "messaging": ["kafka-specialist"],
        "cache": ["cache-specialist"],
        "patterns": ["cqrs-specialist", "resilience-specialist", "distributed-patterns-specialist"],
        "data_access": ["java-migration-specialist", "jpa-hibernate-specialist", "transaction-management-specialist"],
        "search": ["elasticsearch-specialist"],
        "workflow": ["workflow-dag-specialist"],
        "cloud": ["aws-specialist"],
        "security": ["java-security-specialist", "oauth2-specialist", "security-advanced-specialist"],
        "scheduling": ["jobrunr-specialist"],
        "cross_cutting": ["domain-events-specialist", "auditing-specialist", "springdoc-specialist", "sse-specialist", "api-design-governance-specialist", "graphql-spring-specialist", "custom-observability-specialist"],
        "integration": ["http-client-patterns-specialist", "file-handling-specialist"],
        "analytics_ai": ["bi-analytics-specialist", "nl-to-sql-specialist", "llm-integration-specialist"],
        "infrastructure": ["docker-specialist", "docker-compose-specialist", "consul-specialist", "monitoring-specialist", "logging-specialist", "spring-profiles-specialist", "maven-multimodule-specialist", "keycloak-specialist", "maven-advanced-specialist", "ci-cd-patterns-specialist", "kubernetes-spring-specialist"],
        "quality": ["java-perf-specialist", "testing-advanced-specialist"]
      },
      "specialistDir": "java-springboot",
      "kb_path": {
        "backend": ".claude/utils/knowledge-base/backend-kb.json",
        "database": ".claude/utils/knowledge-base/database-kb.json"
      }
    },
    "reactive": {
      "name": "Reactive WebFlux Stack",
      "description": "Spring WebFlux with R2DBC, Kafka, multi-tenancy, and full enterprise stack",
      "detection": {
        "files": ["pom.xml", "build.gradle", "build.gradle.kts"],
        "requires": ["spring-boot-starter-webflux"],
        "priority": 1
      },
      "validation": {
        "files": ["pom.xml", "build.gradle", "build.gradle.kts"],
        "mustHave": ["spring-boot-starter-webflux"],
        "mustNotHave": ["spring-boot-starter-data-jpa"]
      },
      "patterns": {
        "use_jpa": false,
        "use_spring_data": false,
        "use_webflux": true,
        "use_r2dbc": true,
        "use_router_function": true,
        "use_jdbc_template": false,
        "use_kafka": true,
        "use_redis": true,
        "use_elasticsearch": true,
        "use_multitenancy": true,
        "use_cqrs_lite": true,
        "use_mapstruct": true,
        "use_keycloak": true,
        "use_consul": true,
        "use_resilience4j": true,
        "use_s3": true,
        "use_jobrunr": true
      },
      "specialists": {
        "java_language": ["java-fundamentals-specialist", "java-concurrency-specialist", "java-code-quality-specialist", "java-design-patterns-specialist"],
        "spring_core": ["spring-boot-configuration-specialist", "spring-aop-specialist"],
        "architecture": ["backend-clean-architecture-specialist", "architecture-patterns-specialist"],
        "reactive_core": ["java-webflux-specialist", "java-r2dbc-specialist", "java-reactive-specialist", "java-handler-specialist", "java-router-specialist"],
        "standard": ["java-domain-specialist", "java-service-specialist", "java-repository-specialist", "java-controller-specialist", "java-dto-specialist", "java-validation-specialist", "java-exception-specialist", "java-mapper-specialist", "java-di-specialist"],
        "lightweight": ["java-jdbc-specialist", "java-dao-specialist", "java-pojo-specialist"],
        "annotated_controller": ["annotated-reactive-controller-specialist"],
        "crud_patterns": ["crud-service-base-specialist", "search-criteria-specialist", "pagination-specialist", "viewmodel-specialist"],
        "messaging": ["kafka-specialist"],
        "multitenancy": ["multitenancy-specialist"],
        "cache": ["cache-specialist"],
        "patterns": ["cqrs-specialist", "resilience-specialist", "distributed-patterns-specialist"],
        "data_access": ["r2dbc-callback-specialist", "java-data-access-specialist", "java-migration-specialist", "r2dbc-connection-specialist", "r2dbc-database-client-specialist", "r2dbc-transaction-specialist", "r2dbc-rowmapper-specialist", "jpa-hibernate-specialist", "transaction-management-specialist"],
        "gateway": ["gateway-specialist"],
        "search": ["elasticsearch-specialist"],
        "workflow": ["workflow-dag-specialist"],
        "cloud": ["aws-specialist"],
        "security": ["java-security-specialist", "oauth2-specialist", "security-advanced-specialist"],
        "scheduling": ["jobrunr-specialist"],
        "cross_cutting": ["domain-events-specialist", "auditing-specialist", "springdoc-specialist", "sse-specialist", "api-design-governance-specialist", "graphql-spring-specialist", "custom-observability-specialist"],
        "integration": ["http-client-patterns-specialist", "file-handling-specialist"],
        "analytics_ai": ["bi-analytics-specialist", "nl-to-sql-specialist", "llm-integration-specialist"],
        "infrastructure": ["docker-specialist", "docker-compose-specialist", "consul-specialist", "monitoring-specialist", "logging-specialist", "spring-profiles-specialist", "maven-multimodule-specialist", "keycloak-specialist", "maven-advanced-specialist", "ci-cd-patterns-specialist", "kubernetes-spring-specialist"],
        "quality": ["java-testing-specialist", "java-perf-specialist", "testing-advanced-specialist"]
      },
      "specialistDir": "java-springboot",
      "kb_path": {
