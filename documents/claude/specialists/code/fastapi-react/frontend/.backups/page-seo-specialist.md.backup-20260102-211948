// Pattern 5: Tag-Based Revalidation (Server Actions)
// Use case: Manual cache invalidation on content updates
import { revalidateTag, revalidatePath } from 'next/cache';

export async function updateContract(id: string, data: any) {
  // Update the contract in the database
  const response = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/contracts/${id}`,
    {
      method: 'PUT',
      body: JSON.stringify(data),
    }
  );

  if (response.ok) {
    // Invalidate cache for this specific contract
    revalidateTag(`contract-${id}`);
    // Also invalidate the contracts list
    revalidateTag('contracts');
    // Optionally revalidate entire path
    revalidatePath(`/contracts/${id}`);
  }

  return response.json();
}
```

**Technology Notes**:
- `cache: 'no-store'` - Always fetch fresh (best for real-time)
- `next: { revalidate: 60 }` - ISR with 60-second revalidation
- `next: { tags: ['contracts'] }` - Tag-based cache invalidation
- `Promise.all()` - Parallel fetching for better performance
- `revalidateTag()` - On-demand revalidation from server actions

