## Pattern 9.31-9.35: Route Guards - Multi-Level Access Control
## Pattern 9.31-9.35: Bảo Vệ Định Tuyến - Kiểm Soát Truy Cập Đa Cấp

### Purpose / Mục Đích
Implement multi-level route protection: Auth, Role, Permission, Subscription, Maintenance.

### Implementation / Cài Đặt

```typescript
// src/features/auth/guards/useRouteGuards.ts
'use client';

import { useEffect, useState } from 'react';
import { useRouter } from 'next/navigation';
import { useAuthStore } from '@/app/providers/StoreProvider';

export interface GuardConfig {
  requiresAuth?: boolean;
  requiredRoles?: string[];
  requiredPermissions?: string[];
  requiredSubscription?: 'free' | 'pro' | 'enterprise';
  maintenanceMode?: boolean;
}

export function useRouteGuards(config: GuardConfig) {
  const router = useRouter();
  const { isAuthenticated, user } = useAuthStore();
  const [isChecking, setIsChecking] = useState(true);
  const [accessDenied, setAccessDenied] = useState<string | null>(null);

  useEffect(() => {
    // Check authentication
    if (config.requiresAuth && !isAuthenticated) {
      setAccessDenied('unauthenticated');
      router.push('/login');
      return;
    }

    // Check maintenance mode
    if (config.maintenanceMode) {
      setAccessDenied('maintenance');
      return;
    }

    // Check required roles
    if (config.requiredRoles && isAuthenticated && user) {
      const userRoles = (user.roles || []) as string[];
      const hasRequiredRole = config.requiredRoles.some((role) =>
        userRoles.includes(role)
      );

      if (!hasRequiredRole) {
        setAccessDenied('insufficient-role');
        router.push('/unauthorized');
        return;
      }
    }

    // Check required permissions
    if (config.requiredPermissions && isAuthenticated && user) {
      const userPermissions = (user.permissions || []) as string[];
      const hasAllPermissions = config.requiredPermissions.every((permission) =>
        userPermissions.includes(permission)
      );

      if (!hasAllPermissions) {
        setAccessDenied('insufficient-permission');
        router.push('/unauthorized');
        return;
      }
    }

    // Check subscription level
    if (config.requiredSubscription && isAuthenticated && user) {
      const subscriptionLevels = { free: 1, pro: 2, enterprise: 3 };
      const userLevel =
        subscriptionLevels[user.subscription as keyof typeof subscriptionLevels] || 0;
      const requiredLevel =
        subscriptionLevels[
          config.requiredSubscription as keyof typeof subscriptionLevels
        ];

      if (userLevel < requiredLevel) {
        setAccessDenied('insufficient-subscription');
        router.push('/subscription-required');
        return;
      }
    }

    setIsChecking(false);
  }, [isAuthenticated, user, config, router]);

  return {
    isChecking,
    accessDenied,
    isAllowed: !accessDenied && !isChecking,
  };
}

// RoleGuard component
export function RoleGuard({
  children,
  requiredRoles,
  fallback,
}: {
  children: React.ReactNode;
  requiredRoles: string[];
  fallback?: React.ReactNode;
}) {
  const { isChecking, isAllowed } = useRouteGuards({
    requiresAuth: true,
    requiredRoles,
  });

  if (isChecking) {
    return fallback || <RoleGuardSkeleton />;
  }

  if (!isAllowed) {
    return null;
  }

  return <>{children}</>;
}

// PermissionGuard component
export function PermissionGuard({
  children,
  requiredPermissions,
  fallback,
}: {
  children: React.ReactNode;
  requiredPermissions: string[];
  fallback?: React.ReactNode;
}) {
  const { isChecking, isAllowed } = useRouteGuards({
    requiresAuth: true,
    requiredPermissions,
  });

  if (isChecking) {
    return fallback || <PermissionGuardSkeleton />;
  }

  if (!isAllowed) {
    return null;
  }

  return <>{children}</>;
}

// SubscriptionGuard component
export function SubscriptionGuard({
  children,
  requiredSubscription,
  fallback,
}: {
  children: React.ReactNode;
  requiredSubscription: 'free' | 'pro' | 'enterprise';
  fallback?: React.ReactNode;
}) {
  const { isChecking, isAllowed } = useRouteGuards({
    requiresAuth: true,
    requiredSubscription,
  });

  if (isChecking) {
    return fallback || <SubscriptionGuardSkeleton />;
  }

  if (!isAllowed) {
    return null;
  }

  return <>{children}</>;
}

function RoleGuardSkeleton() {
  return <div className="h-64 bg-gray-200 rounded animate-pulse" />;
}

function PermissionGuardSkeleton() {
  return <div className="h-64 bg-gray-200 rounded animate-pulse" />;
}

function SubscriptionGuardSkeleton() {
  return <div className="h-64 bg-gray-200 rounded animate-pulse" />;
}

// Usage in components
export function AdminPanel() {
  return (
    <RoleGuard requiredRoles={['admin']}>
      <div className="space-y-4">
        <h1 className="text-2xl font-bold">Bảng Điều Khiển Quản Trị / Admin Panel</h1>
        {/* Admin content */}
      </div>
    </RoleGuard>
  );
}

export function ContractEditor() {
  return (
    <PermissionGuard requiredPermissions={['contracts:write', 'contracts:delete']}>
      <div className="space-y-4">
        <h1 className="text-2xl font-bold">Chỉnh Sửa Hợp Đồng / Edit Contract</h1>
        {/* Editor content */}
      </div>
    </PermissionGuard>
  );
}

export function AdvancedFeatures() {
  return (
    <SubscriptionGuard requiredSubscription="pro">
      <div className="space-y-4">
        <h1 className="text-2xl font-bold">Tính Năng Nâng Cao / Advanced Features</h1>
        {/* Advanced features content */}
      </div>
    </SubscriptionGuard>
  );
}
```

