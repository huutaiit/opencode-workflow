## Pattern 9.25: RouteErrorBoundary - Route-Level Error Handling
## Pattern 9.25: RouteErrorBoundary - Xử Lý Lỗi Cấp Định Tuyến

### Purpose / Mục Đích
Handle errors at route level with custom error boundaries and recovery.

### Implementation / Cài Đặt

```typescript
// src/app/(legal)/contracts/[contractId]/error.tsx
'use client';

import { useEffect } from 'react';
import { AlertTriangle, RefreshCw, Home } from 'lucide-react';
import Link from 'next/link';

interface ContractErrorProps {
  error: Error & { digest?: string };
  reset: () => void;
}

export default function ContractError({ error, reset }: ContractErrorProps) {
  useEffect(() => {
    // Log error details
    console.error('Contract page error:', error);
  }, [error]);

  return (
    <div className="min-h-screen flex items-center justify-center bg-gray-50 px-4">
      <div className="max-w-md w-full bg-white rounded-lg shadow-lg p-8">
        <div className="flex items-center justify-center w-12 h-12 mx-auto bg-red-100 rounded-full">
          <AlertTriangle className="w-6 h-6 text-red-600" />
        </div>

        <h1 className="mt-4 text-2xl font-bold text-center text-gray-900">
          Lỗi Tải Hợp Đồng / Error Loading Contract
        </h1>

        <p className="mt-2 text-sm text-center text-gray-600">
          Xin lỗi, không thể tải hợp đồng. Vui lòng thử lại sau. / Sorry, we couldn't load the
          contract. Please try again.
        </p>

        {process.env.NODE_ENV === 'development' && (
          <div className="mt-4 p-4 bg-gray-100 rounded border-l-4 border-red-500">
            <p className="text-xs font-mono text-red-600 font-semibold">Error Details:</p>
            <p className="text-xs font-mono text-gray-700 mt-2">{error.message}</p>
            {error.digest && (
              <p className="text-xs font-mono text-gray-500 mt-2">ID: {error.digest}</p>
            )}
          </div>
        )}

        <div className="mt-6 space-y-3">
          <button
            onClick={reset}
            className="w-full flex items-center justify-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium"
          >
            <RefreshCw className="w-4 h-4 mr-2" />
            Thử Lại / Try Again
          </button>

          <Link
            href="/legal/contracts"
            className="w-full flex items-center justify-center px-4 py-2 bg-gray-100 text-gray-900 rounded-lg hover:bg-gray-200 transition-colors font-medium"
          >
            <Home className="w-4 h-4 mr-2" />
            Quay Lại Danh Sách / Back to List
          </Link>
        </div>
      </div>
    </div>
  );
}

// src/app/(legal)/error.tsx - Legal group error boundary
'use client';

import { useEffect } from 'react';
import { AlertTriangle, RefreshCw, Home } from 'lucide-react';
import Link from 'next/link';

interface LegalErrorProps {
