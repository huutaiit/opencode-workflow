## Testing Patterns / Mẫu Kiểm Tra

### Route Navigation Tests / Kiểm Tra Điều Hướng Định Tuyến

```typescript
// tests/routes.spec.ts
import { describe, it, expect, beforeEach } from 'vitest';
import { render, screen } from '@testing-library/react';
import { useRouter } from 'next/navigation';

describe('Route Navigation', () => {
  it('should navigate from home to contracts list', async () => {
    const { user } = render(<HomePage />);

    const contractsLink = screen.getByRole('link', { name: /hợp đồng/i });
    await user.click(contractsLink);

    expect(useRouter().push).toHaveBeenCalledWith('/legal/contracts');
  });

  it('should navigate to contract detail page', async () => {
    const { user } = render(<ContractsList />);

    const contractLink = screen.getAllByRole('link')[0];
    await user.click(contractLink);

    expect(useRouter().push).toHaveBeenCalled();
  });
});
```

### Route Guard Tests / Kiểm Tra Bảo Vệ Định Tuyến

```typescript
// tests/guards.spec.ts
import { describe, it, expect } from 'vitest';
import { render, screen } from '@testing-library/react';
import { AuthGuard } from '@/features/auth/components/AuthGuard';

describe('AuthGuard', () => {
  it('should show loading state while checking authentication', () => {
    render(
      <AuthGuard>
        <div>Protected Content</div>
      </AuthGuard>
    );

    expect(screen.getByText(/loading/i)).toBeInTheDocument();
  });

  it('should show protected content when authenticated', async () => {
    // Mock authenticated user
    vi.mocked(useAuthStore).mockReturnValue({
      isAuthenticated: true,
      user: { id: '1', name: 'User', roles: ['user'] },
    });

    render(
      <AuthGuard>
        <div>Protected Content</div>
      </AuthGuard>
    );

    await waitFor(() => {
      expect(screen.getByText('Protected Content')).toBeInTheDocument();
    });
  });

  it('should redirect to login when not authenticated', () => {
    vi.mocked(useAuthStore).mockReturnValue({
      isAuthenticated: false,
      user: null,
    });

    render(
      <AuthGuard>
        <div>Protected Content</div>
      </AuthGuard>
    );

    expect(useRouter().push).toHaveBeenCalledWith('/login');
  });
});
```

### Protected Route Tests / Kiểm Tra Tuyến Đường Được Bảo Vệ

```typescript
// tests/e2e/routes.spec.ts (Playwright)
import { test, expect } from '@playwright/test';

test.describe('Protected Routes', () => {
  test('should redirect unauthenticated user to login', async ({ page }) => {
    await page.goto('/legal/contracts');
    expect(page.url()).toContain('/login');
  });

  test('should allow authenticated user to access protected route', async ({
    page,
    context,
  }) => {
    // Set authentication cookie
    await context.addCookies([
      {
        name: 'auth-token',
        value: 'valid-token',
        url: 'http://localhost:3000',
      },
    ]);

    await page.goto('/legal/contracts');
    expect(page.url()).toContain('/legal/contracts');
  });

  test('should show role-based UI based on user permissions', async ({
    page,
    context,
  }) => {
    // Lawyer user
    await context.addCookies([
      {
        name: 'auth-token',
        value: 'lawyer-token',
        url: 'http://localhost:3000',
      },
    ]);

    await page.goto('/legal/contracts');

    // Should see edit button
    expect(await page.getByRole('button', { name: /chỉnh sửa/i })).toBeVisible();
  });
});
```

### Mobile Navigation Tests / Kiểm Tra Điều Hướng Di Động

```typescript
// tests/mobile-nav.spec.ts
import { describe, it, expect } from 'vitest';
import { render, screen } from '@testing-library/react';
import { userEvent } from '@testing-library/user-event';
import { MobileNav } from '@/widgets/mobile-nav/MobileNav';

describe('Mobile Navigation', () => {
  it('should render bottom navigation on mobile', () => {
    render(<MobileNav />, {
      viewport: { width: 375, height: 667 },
    });

    expect(screen.getByRole('navigation')).toBeVisible();
  });

  it('should show more menu when more button clicked', async () => {
    const user = userEvent.setup();

    render(<MobileNav />, {
      viewport: { width: 375, height: 667 },
    });

    const moreButton = screen.getByRole('button', { name: /thêm/i });
    await user.click(moreButton);

    expect(screen.getByText(/vụ án/i)).toBeVisible();
  });

  it('should highlight active navigation item', () => {
    render(<MobileNav />, {
      viewport: { width: 375, height: 667 },
    });

    const dashboardLink = screen.getByRole('link', { name: /bảng điều khiển/i });
    expect(dashboardLink.parentElement).toHaveClass('text-blue-600');
  });
});
```

