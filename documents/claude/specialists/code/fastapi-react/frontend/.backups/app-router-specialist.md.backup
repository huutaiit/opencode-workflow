## Pattern 9.27: Sidebar - Side Navigation Component
## Pattern 9.27: Sidebar - Thành Phần Điều Hướng Bên

### Purpose / Mục Đích
Create collapsible sidebar with navigation groups and visual indicators.

### Implementation / Cài Đặt

```typescript
// src/widgets/sidebar/Sidebar.tsx
'use client';

import Link from 'next/link';
import { usePathname } from 'next/navigation';
import {
  LayoutDashboard,
  FileText,
  Briefcase,
  Scale,
  ChevronDown,
  ChevronRight,
} from 'lucide-react';
import { useUIStore } from '@/app/providers/StoreProvider';
import { useState } from 'react';
import { navigationMenu } from '@/shared/config/routes';

export function Sidebar() {
  const pathname = usePathname();
  const { sidebarOpen } = useUIStore();
  const [expandedGroups, setExpandedGroups] = useState<Record<string, boolean>>({
    legal: true,
  });

  const toggleGroup = (group: string) => {
    setExpandedGroups((prev) => ({
      ...prev,
      [group]: !prev[group],
    }));
  };

  const isActive = (path: string) => {
    return pathname === path || pathname.startsWith(`${path}/`);
  };

  // Group routes by category
  const groupedRoutes = navigationMenu.reduce(
    (acc, route) => {
      const group = route.group;
      if (!acc[group]) {
        acc[group] = [];
      }
      acc[group].push(route);
      return acc;
    },
    {} as Record<string, typeof navigationMenu>
  );

  if (!sidebarOpen) return null;

  return (
    <aside className="hidden lg:flex flex-col w-64 bg-gray-50 border-r border-gray-200 overflow-y-auto">
      <nav className="flex-1 px-4 py-6 space-y-2">
        {/* Dashboard section */}
        {groupedRoutes['dashboard'] && (
          <div className="space-y-1">
            <div className="px-2 py-2">
              <p className="text-xs font-semibold text-gray-500 uppercase">
                Quản Lý / Management
              </p>
            </div>
            {groupedRoutes['dashboard'].map((route) => (
              <Link
                key={route.path}
                href={route.path}
                className={`flex items-center gap-3 px-3 py-2 rounded-lg transition-colors ${
                  isActive(route.path)
                    ? 'bg-blue-100 text-blue-600 font-medium'
                    : 'text-gray-700 hover:bg-gray-100'
                }`}
              >
                <LayoutDashboard className="w-4 h-4 flex-shrink-0" />
                <span className="text-sm">{route.labelVi}</span>
              </Link>
            ))}
          </div>
        )}

        {/* Legal section */}
        {groupedRoutes['legal'] && (
          <div className="space-y-1 mt-6">
            <button
              onClick={() => toggleGroup('legal')}
              className="w-full flex items-center justify-between px-2 py-2 text-xs font-semibold text-gray-500 uppercase hover:text-gray-700 transition-colors"
            >
              <span>Pháp Lý / Legal</span>
              {expandedGroups['legal'] ? (
                <ChevronDown className="w-4 h-4" />
              ) : (
                <ChevronRight className="w-4 h-4" />
              )}
            </button>

            {expandedGroups['legal'] && (
              <div className="space-y-1 ml-2 border-l-2 border-gray-200 pl-2">
                {groupedRoutes['legal'].map((route) => {
                  const getIcon = (path: string) => {
                    if (path.includes('contracts'))
                      return <Briefcase className="w-4 h-4 flex-shrink-0" />;
                    if (path.includes('documents'))
                      return <FileText className="w-4 h-4 flex-shrink-0" />;
                    if (path.includes('cases'))
                      return <Scale className="w-4 h-4 flex-shrink-0" />;
                    return null;
                  };

                  return (
                    <Link
                      key={route.path}
                      href={route.path}
                      className={`flex items-center gap-3 px-3 py-2 rounded-lg transition-colors ${
                        isActive(route.path)
                          ? 'bg-green-100 text-green-600 font-medium'
                          : 'text-gray-700 hover:bg-gray-100'
                      }`}
                    >
                      {getIcon(route.path)}
                      <span className="text-sm">{route.labelVi}</span>
                    </Link>
                  );
                })}
              </div>
            )}
          </div>
        )}
      </nav>

      {/* Footer info */}
      <div className="px-4 py-4 border-t border-gray-200 space-y-2">
        <p className="text-xs text-gray-500">
          Phiên Bản / Version<br />
          <span className="font-semibold text-gray-700">v1.0.0</span>
        </p>
      </div>
    </aside>
  );
}
```

---

## Pattern 9.28: Breadcrumbs - Breadcrumb Navigation
## Pattern 9.28: Breadcrumbs - Điều Hướng Dấu Vết

### Purpose / Mục Đích
Show current page location in hierarchy with clickable breadcrumbs.

### Implementation / Cài Đặt

```typescript
// src/widgets/breadcrumbs/Breadcrumbs.tsx
'use client';

import Link from 'next/link';
import { usePathname } from 'next/navigation';
import { ChevronRight, Home } from 'lucide-react';

export interface BreadcrumbItem {
  label: string;
  href?: string;
  labelVi?: string;
}

interface BreadcrumbsProps {
  items?: BreadcrumbItem[];
  showHome?: boolean;
}

export function Breadcrumbs({ items, showHome = true }: BreadcrumbsProps) {
  const pathname = usePathname();

  // Generate breadcrumbs from pathname if items not provided
  const breadcrumbs = items || generateBreadcrumbs(pathname);

  if (breadcrumbs.length === 0) return null;

  return (
    <nav
      className="flex items-center gap-2 px-4 py-3 bg-white rounded-lg border border-gray-200"
      aria-label="Breadcrumb"
    >
      <ol className="flex items-center gap-2">
        {showHome && (
          <>
            <li>
              <Link
                href="/dashboard"
                className="p-1 hover:bg-gray-100 rounded transition-colors"
                aria-label="Dashboard"
              >
                <Home className="w-4 h-4 text-gray-600" />
              </Link>
            </li>
            {breadcrumbs.length > 0 && (
              <li className="text-gray-400">
                <ChevronRight className="w-4 h-4" />
              </li>
            )}
          </>
        )}

        {breadcrumbs.map((item, index) => {
          const isLast = index === breadcrumbs.length - 1;

          return (
            <li key={item.label} className="flex items-center gap-2">
              {item.href ? (
                <Link
                  href={item.href}
                  className="text-sm text-blue-600 hover:text-blue-800 transition-colors"
                >
                  {item.labelVi || item.label}
                </Link>
              ) : (
                <span className={isLast ? 'text-sm font-medium text-gray-900' : 'text-sm text-gray-600'}>
                  {item.labelVi || item.label}
                </span>
              )}

              {!isLast && (
                <ChevronRight className="w-4 h-4 text-gray-400" />
              )}
            </li>
          );
        })}
      </ol>
    </nav>
  );
}

// Helper function to generate breadcrumbs from pathname
function generateBreadcrumbs(pathname: string): BreadcrumbItem[] {
  const segments = pathname.split('/').filter(Boolean);
  const breadcrumbs: BreadcrumbItem[] = [];

  const breadcrumbMap: Record<string, { label: string; labelVi: string }> = {
    legal: { label: 'Legal', labelVi: 'Pháp Lý' },
    contracts: { label: 'Contracts', labelVi: 'Hợp Đồng' },
    documents: { label: 'Documents', labelVi: 'Tài Liệu' },
    cases: { label: 'Cases', labelVi: 'Vụ Án' },
    dashboard: { label: 'Dashboard', labelVi: 'Bảng Điều Khiển' },
    users: { label: 'Users', labelVi: 'Người Dùng' },
    settings: { label: 'Settings', labelVi: 'Cài Đặt' },
  };

  segments.forEach((segment, index) => {
    // Skip numeric IDs and special segments
    if (/^[0-9a-f-]+$/.test(segment)) {
      breadcrumbs.push({
        label: 'Details / Chi Tiết',
        labelVi: 'Chi Tiết',
      });
      return;
    }

    const map = breadcrumbMap[segment];
    if (map) {
      const href = '/' + segments.slice(0, index + 1).join('/');
      breadcrumbs.push({
        label: map.label,
        labelVi: map.labelVi,
        href: index < segments.length - 1 ? href : undefined,
      });
    }
  });

  return breadcrumbs;
}
```

---

## Pattern 9.29: TabNavigation - Tab-Based Navigation
## Pattern 9.29: TabNavigation - Điều Hướng Dựa Trên Tab

### Purpose / Mục Đích
Create tabbed interface for organizing related content sections.

### Implementation / Cài Đặt

```typescript
// src/widgets/tabs/TabNavigation.tsx
'use client';

import { useState, useCallback } from 'react';
import { useSearchParams } from 'next/navigation';

export interface TabItem {
  id: string;
  label: string;
  labelVi?: string;
  content: React.ReactNode;
  badge?: string;
}

interface TabNavigationProps {
  tabs: TabItem[];
  defaultTab?: string;
  onChange?: (tabId: string) => void;
  variant?: 'default' | 'underline' | 'pills';
}

export function TabNavigation({
  tabs,
  defaultTab,
  onChange,
  variant = 'default',
}: TabNavigationProps) {
  const searchParams = useSearchParams();
  const tabParam = searchParams.get('tab');
  const [activeTab, setActiveTab] = useState(tabParam || defaultTab || tabs[0]?.id);

  const handleTabChange = useCallback(
    (tabId: string) => {
      setActiveTab(tabId);
      onChange?.(tabId);
    },
    [onChange]
  );

  const activeTabContent = tabs.find((tab) => tab.id === activeTab);

  return (
    <div className="space-y-6">
      {/* Tab buttons */}
      <div className={getTabContainerClassName(variant)}>
        {tabs.map((tab) => (
          <button
            key={tab.id}
            onClick={() => handleTabChange(tab.id)}
            className={getTabButtonClassName(activeTab === tab.id, variant)}
          >
            <span>{tab.labelVi || tab.label}</span>
            {tab.badge && (
              <span className="ml-2 inline-flex items-center justify-center px-2 py-1 text-xs font-semibold text-white bg-red-600 rounded-full">
                {tab.badge}
              </span>
            )}
          </button>
        ))}
      </div>

      {/* Tab content */}
      <div className="animate-fade-in">{activeTabContent?.content}</div>
    </div>
  );
}

function getTabContainerClassName(variant: string): string {
  const baseClass = 'flex items-center gap-0 border-b border-gray-200';
  switch (variant) {
    case 'underline':
      return baseClass;
    case 'pills':
      return 'flex items-center gap-2 bg-gray-100 rounded-lg p-1';
    default:
      return baseClass;
  }
}

function getTabButtonClassName(isActive: boolean, variant: string): string {
  const baseClass = 'px-4 py-2 font-medium text-sm transition-colors relative';

  switch (variant) {
    case 'underline':
      return `${baseClass} ${
        isActive
          ? 'text-blue-600 border-b-2 border-blue-600'
          : 'text-gray-600 hover:text-gray-900'
      }`;
    case 'pills':
      return `${baseClass} rounded-md ${
        isActive
          ? 'bg-white text-blue-600 shadow-sm'
          : 'text-gray-600 hover:text-gray-900'
      }`;
    default:
      return `${baseClass} ${
        isActive
          ? 'text-blue-600 border-b-2 border-blue-600'
          : 'text-gray-600 hover:text-gray-900'
      }`;
  }
}

// Usage example for contract detail page
export function ContractDetailTabs({ contractId }: { contractId: string }) {
  const tabs: TabItem[] = [
    {
      id: 'overview',
      label: 'Overview / Tổng Quan',
      labelVi: 'Tổng Quan',
      content: <ContractOverview contractId={contractId} />,
    },
    {
      id: 'documents',
      label: 'Documents / Tài Liệu',
      labelVi: 'Tài Liệu',
      content: <ContractDocuments contractId={contractId} />,
      badge: '3',
    },
    {
      id: 'timeline',
      label: 'Timeline / Lịch Sử',
      labelVi: 'Lịch Sử',
      content: <ContractTimeline contractId={contractId} />,
    },
    {
      id: 'comments',
      label: 'Comments / Bình Luận',
      labelVi: 'Bình Luận',
      content: <ContractComments contractId={contractId} />,
      badge: '5',
    },
  ];

  return <TabNavigation tabs={tabs} defaultTab="overview" variant="underline" />;
}
```

