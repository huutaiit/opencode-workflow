### Global Styles / Kiểu Dáng Toàn Cầu

```css
/* src/app/globals.css */

@import 'tailwindcss/base';
@import 'tailwindcss/components';
@import 'tailwindcss/utilities';

/* Root variables */
:root {
  --color-primary: #0066cc;
  --color-primary-dark: #0052a3;
  --color-secondary: #10b981;
  --color-danger: #ef4444;
  --color-warning: #f59e0b;
  --color-success: #10b981;
  --color-gray-50: #f9fafb;
  --color-gray-900: #111827;

  /* Spacing */
  --spacing-xs: 0.25rem;
  --spacing-sm: 0.5rem;
  --spacing-md: 1rem;
  --spacing-lg: 1.5rem;
  --spacing-xl: 2rem;

  /* Border radius */
  --radius-sm: 0.375rem;
  --radius-md: 0.5rem;
  --radius-lg: 0.75rem;

  /* Safe area for mobile */
  --safe-area-inset-top: max(12px, env(safe-area-inset-top));
  --safe-area-inset-right: max(12px, env(safe-area-inset-right));
  --safe-area-inset-bottom: max(12px, env(safe-area-inset-bottom));
  --safe-area-inset-left: max(12px, env(safe-area-inset-left));
}

/* HTML */
html {
  scroll-behavior: smooth;
}

/* Body */
body {
  background-color: #f9fafb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto Oxide',
    'Droid Sans', 'Helvetica Neue', sans-serif;
}

/* Typography */
h1,
h2,
h3,
h4,
h5,
h6 {
  @apply font-bold tracking-tight;
}

h1 {
  @apply text-3xl lg:text-4xl;
}

h2 {
  @apply text-2xl lg:text-3xl;
}

h3 {
  @apply text-xl lg:text-2xl;
}

/* Links */
a {
  @apply text-blue-600 hover:text-blue-800 transition-colors;
}

a:visited {
  @apply text-purple-600 hover:text-purple-800;
}

/* Buttons */
button {
  @apply transition-colors;
}

button:focus {
  @apply outline-none ring-2 ring-blue-500 ring-offset-2;
}

/* Form inputs */
input,
textarea,
select {
  @apply rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
}

input:disabled,
textarea:disabled,
select:disabled {
  @apply bg-gray-50 text-gray-500 cursor-not-allowed;
}

/* Placeholder */
::placeholder {
  @apply text-gray-400;
}

/* Selection */
::selection {
  @apply bg-blue-600 text-white;
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: #f1f5f9;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* Animations */
@keyframes fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slide-in-up {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse-slow {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.animate-fade-in {
  animation: fade-in 0.3s ease-in-out;
}

.animate-slide-in-up {
  animation: slide-in-up 0.3s ease-in-out;
}

.animate-pulse-slow {
  animation: pulse-slow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* Safe area utilities */
.safe-area-inset-top {
  padding-top: var(--safe-area-inset-top);
}

.safe-area-inset-bottom {
  padding-bottom: var(--safe-area-inset-bottom);
}

/* Utility classes */
.truncate-lines-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.truncate-lines-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Print styles */
@media print {
  body {
    background: white;
  }

  a {
    text-decoration: underline;
  }

  .no-print {
    display: none !important;
  }
}

/* Dark mode */
@media (prefers-color-scheme: dark) {
  html {
    color-scheme: dark;
  }

  body {
    @apply bg-gray-900 text-gray-100;
  }
}

/* Accessibility */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}
```

