## Pattern 9.30: MobileNav - Mobile Navigation
## Pattern 9.30: MobileNav - Điều Hướng Trên Thiết Bị Di Động

### Purpose / Mục Đích
Create mobile-optimized bottom navigation for touch devices.

### Implementation / Cài Đặt

```typescript
// src/widgets/mobile-nav/MobileNav.tsx
'use client';

import Link from 'next/link';
import { usePathname } from 'next/navigation';
import {
  LayoutDashboard,
  FileText,
  Briefcase,
  Scale,
  MoreVertical,
} from 'lucide-react';
import { useState } from 'react';
import { useClickOutside } from '@/shared/hooks/useClickOutside';

interface MobileNavItem {
  id: string;
  label: string;
  labelVi: string;
  href: string;
  icon: React.ReactNode;
  badge?: string;
}

export function MobileNav() {
  const pathname = usePathname();
  const [moreMenuOpen, setMoreMenuOpen] = useState(false);
  const moreMenuRef = useClickOutside(() => setMoreMenuOpen(false));

  const navItems: MobileNavItem[] = [
    {
      id: 'dashboard',
      label: 'Dashboard',
      labelVi: 'Bảng Điều Khiển',
      href: '/dashboard',
      icon: <LayoutDashboard className="w-6 h-6" />,
    },
    {
      id: 'contracts',
      label: 'Contracts',
      labelVi: 'Hợp Đồng',
      href: '/legal/contracts',
      icon: <Briefcase className="w-6 h-6" />,
    },
    {
      id: 'documents',
      label: 'Documents',
      labelVi: 'Tài Liệu',
      href: '/legal/documents',
      icon: <FileText className="w-6 h-6" />,
    },
    {
      id: 'cases',
      label: 'Cases',
      labelVi: 'Vụ Án',
      href: '/legal/cases',
      icon: <Scale className="w-6 h-6" />,
    },
  ];

  const primaryItems = navItems.slice(0, 3);
  const moreItems = navItems.slice(3);

  const isActive = (href: string) => {
    return pathname === href || pathname.startsWith(`${href}/`);
  };

  return (
    <nav className="fixed bottom-0 left-0 right-0 lg:hidden bg-white border-t border-gray-200 safe-area-inset-bottom">
      <div className="flex items-center justify-around h-16">
        {/* Primary navigation items */}
        {primaryItems.map((item) => (
          <Link
            key={item.id}
            href={item.href}
            className={`flex flex-col items-center justify-center w-full h-full gap-1 transition-colors ${
              isActive(item.href)
                ? 'text-blue-600 bg-blue-50'
                : 'text-gray-600 hover:text-gray-900'
            }`}
          >
            {item.icon}
            <span className="text-xs font-medium">{item.labelVi}</span>
          </Link>
        ))}

        {/* More menu */}
        {moreItems.length > 0 && (
          <div className="relative h-full w-full" ref={moreMenuRef}>
            <button
              onClick={() => setMoreMenuOpen(!moreMenuOpen)}
              className={`flex flex-col items-center justify-center w-full h-full gap-1 transition-colors ${
                moreMenuOpen
                  ? 'text-blue-600 bg-blue-50'
                  : 'text-gray-600 hover:text-gray-900'
              }`}
            >
              <MoreVertical className="w-6 h-6" />
              <span className="text-xs font-medium">Thêm</span>
            </button>

            {/* More menu dropdown */}
            {moreMenuOpen && (
              <div className="absolute bottom-full right-0 w-40 bg-white rounded-t-lg shadow-lg border border-gray-200 border-b-0">
                {moreItems.map((item) => (
                  <Link
                    key={item.id}
                    href={item.href}
                    onClick={() => setMoreMenuOpen(false)}
                    className={`flex items-center gap-3 px-4 py-3 border-b border-gray-100 last:border-b-0 transition-colors ${
                      isActive(item.href)
                        ? 'bg-blue-50 text-blue-600'
                        : 'text-gray-700 hover:bg-gray-50'
                    }`}
                  >
                    {item.icon}
                    <span className="text-sm font-medium">{item.labelVi}</span>
                  </Link>
                ))}
              </div>
            )}
          </div>
        )}
      </div>
    </nav>
  );
}
```

