## Pattern 9.24: RouteLoader - Data Loading with Suspense
## Pattern 9.24: RouteLoader - Tải Dữ Liệu Bằng Suspense

### Purpose / Mục Đích
Load route data efficiently with Suspense boundaries and skeleton UI.

### Loading UI Implementation / Cài Đặt Giao Diện Tải

```typescript
// src/app/(legal)/contracts/loading.tsx
import { ContractListSkeleton } from '@/features/legal/contracts/components/ContractListSkeleton';

export default function ContractsLoading() {
  return <ContractListSkeleton />;
}

// src/features/legal/contracts/components/ContractListSkeleton.tsx
export function ContractListSkeleton() {
  return (
    <div className="space-y-4">
      {/* Header skeleton */}
      <div className="space-y-2">
        <div className="h-8 w-48 bg-gray-200 rounded animate-pulse" />
        <div className="h-4 w-96 bg-gray-100 rounded animate-pulse" />
      </div>

      {/* Search bar skeleton */}
      <div className="h-10 w-full bg-gray-200 rounded animate-pulse" />

      {/* Table skeleton */}
      <div className="space-y-2">
        {Array.from({ length: 5 }).map((_, i) => (
          <div key={i} className="h-12 bg-gray-100 rounded animate-pulse" />
        ))}
      </div>
    </div>
  );
}

// src/app/(legal)/contracts/[contractId]/loading.tsx
import { ContractDetailSkeleton } from '@/features/legal/contracts/components/ContractDetailSkeleton';

export default function ContractDetailLoading() {
  return <ContractDetailSkeleton />;
}

export const metadata = {
  title: 'Đang Tải... / Loading...',
};

// src/features/legal/contracts/components/ContractDetailSkeleton.tsx
export function ContractDetailSkeleton() {
  return (
    <div className="space-y-6">
      {/* Header skeleton */}
      <div className="space-y-4">
        <div className="h-10 w-2/3 bg-gray-200 rounded animate-pulse" />
        <div className="flex gap-2">
          <div className="h-6 w-24 bg-gray-200 rounded animate-pulse" />
          <div className="h-6 w-24 bg-gray-200 rounded animate-pulse" />
          <div className="h-6 w-24 bg-gray-200 rounded animate-pulse" />
        </div>
      </div>

      {/* Content skeleton */}
      <div className="grid grid-cols-3 gap-4">
        {Array.from({ length: 6 }).map((_, i) => (
          <div key={i} className="space-y-2">
            <div className="h-4 w-24 bg-gray-200 rounded animate-pulse" />
            <div className="h-6 w-full bg-gray-100 rounded animate-pulse" />
          </div>
        ))}
      </div>

      {/* Document viewer skeleton */}
      <div className="h-96 bg-gray-200 rounded animate-pulse" />
    </div>
  );
}
```

### Route Data Loading / Tải Dữ Liệu Định Tuyến

```typescript
// src/app/(legal)/contracts/[contractId]/page.tsx
import { Metadata } from 'next';
import { notFound } from 'next/navigation';
import { ContractDetail } from '@/features/legal/contracts/components/ContractDetail';
import { getContract } from '@/features/legal/contracts/api';

interface ContractPageProps {
  params: Promise<{ contractId: string }>;
}

// Generate metadata for SEO
export async function generateMetadata(
  { params }: ContractPageProps
): Promise<Metadata> {
  const { contractId } = await params;

  try {
    const contract = await getContract(contractId);

    return {
      title: `Hợp Đồng: ${contract.title} | StartX4CRM`,
      description: contract.description || `Xem chi tiết hợp đồng ${contract.title}`,
      openGraph: {
        title: `Hợp Đồng: ${contract.title}`,
        description: contract.description || `Xem chi tiết hợp đồng ${contract.title}`,
        type: 'article',
        publishedTime: contract.createdAt,
        modifiedTime: contract.updatedAt,
      },
    };
  } catch (error) {
    return {
      title: 'Hợp Đồng Không Tìm Thấy | StartX4CRM',
      description: 'The contract could not be found.',
    };
  }
}

// Generate static paths for commonly accessed contracts
export async function generateStaticParams() {
  // This would typically fetch top contracts from your API
  return [
    { contractId: 'contract-1' },
    { contractId: 'contract-2' },
    { contractId: 'contract-3' },
  ];
}

export const revalidate = 60; // Revalidate every 60 seconds

export default async function ContractPage({ params }: ContractPageProps) {
  const { contractId } = await params;

  try {
    const contract = await getContract(contractId);

    if (!contract) {
      notFound();
    }

    return (
      <div className="space-y-6">
        <ContractDetail contract={contract} />
      </div>
    );
  } catch (error) {
    notFound();
  }
}
```

