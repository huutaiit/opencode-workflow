## Feature-Sliced Design Structure / Cấu trúc Design được cắt từ tính năng

```
src/
├── app/
│   ├── layout.tsx                    # Root layout
│   ├── providers.tsx                 # Combined providers
│   ├── globals.css                   # Global styles
│   │
│   ├── providers/                    # Provider directory (App Layer)
│   │   ├── query-provider.tsx        # Pattern 9.1
│   │   ├── theme-provider.tsx        # Pattern 9.2
│   │   ├── auth-provider.tsx         # Pattern 9.3
│   │   ├── i18n-provider.tsx         # Pattern 9.4
│   │   ├── toast-provider.tsx        # Pattern 9.5
│   │   ├── store-provider.tsx        # Patterns 9.6-9.10
│   │   ├── error-boundary.tsx        # Patterns 9.11-9.15
│   │   ├── suspense-provider.tsx     # Pattern 9.16-9.18
│   │   ├── optimization-provider.tsx # Pattern 9.19-9.20
│   │   └── index.ts                  # Export all providers
│   │
│   ├── (auth)/                       # Auth routes group
│   │   ├── layout.tsx
│   │   ├── login/
│   │   │   └── page.tsx
│   │   └── register/
│   │       └── page.tsx
│   │
│   ├── (dashboard)/                  # Dashboard routes group
│   │   ├── layout.tsx
│   │   ├── page.tsx
│   │   ├── documents/
│   │   │   ├── page.tsx
│   │   │   └── [id]/
│   │   │       └── page.tsx
│   │   └── conversations/
│   │       ├── page.tsx
│   │       └── [id]/
│   │           └── page.tsx
│   │
│   └── api/                          # API routes
│       ├── auth/
│       └── trpc/
│
├── shared/                           # Shared layer
│   ├── api/                          # API clients
│   │   ├── user.ts
│   │   ├── documents.ts
│   │   └── conversations.ts
│   ├── types/                        # Shared types
│   │   └── models.ts
│   └── lib/                          # Utilities
│       └── validators.ts
│
└── features/                         # Feature modules
    ├── documents/                    # Document feature
    │   ├── api/
    │   ├── components/
    │   ├── hooks/
    │   └── types/
    └── conversations/                # Conversation feature
        ├── api/
        ├── components/
        ├── hooks/
        └── types/
```

