## Pattern 9.16: SuspenseProvider
## Mẫu 9.16: SuspenseProvider

**Purpose**: React Suspense wrapper for lazy loading and code splitting.
**Mục đích**: Bao bọc React Suspense để tải lười biếng và phân chia mã.

**File**: `src/app/providers/suspense-provider.tsx`

### Implementation / Triển khai

```typescript
'use client';

import { ReactNode, Suspense } from 'react';
import { Loader2 } from 'lucide-react';

/**
 * Suspense Provider Props
 */
interface SuspenseProviderProps {
  children: ReactNode;
}

/**
 * Default loading fallback
 * Dự phòng tải mặc định
 */
function DefaultLoadingFallback() {
  return (
    <div className="flex items-center justify-center min-h-screen">
      <div className="space-y-4">
        <Loader2 className="w-8 h-8 animate-spin mx-auto text-blue-600" />
        <p className="text-sm text-gray-600 dark:text-gray-400">
          Đang tải / Loading...
        </p>
      </div>
    </div>
  );
}

/**
 * Suspense Boundary Component
 * Component ranh giới Suspense
 */
export function SuspenseBoundary({
  children,
  fallback = <DefaultLoadingFallback />,
}: {
  children: ReactNode;
  fallback?: ReactNode;
}) {
  return <Suspense fallback={fallback}>{children}</Suspense>;
}

/**
 * Legal document loading fallback
 * Dự phòng tải tài liệu pháp lý
 */
function LegalDocumentLoadingFallback() {
  return (
    <div className="space-y-4 p-6">
      {/* Document header skeleton */}
      <div className="h-8 bg-gray-200 dark:bg-gray-700 rounded w-3/4 animate-pulse" />

      {/* Document content skeleton */}
      <div className="space-y-2">
        <div className="h-4 bg-gray-200 dark:bg-gray-700 rounded w-full animate-pulse" />
        <div className="h-4 bg-gray-200 dark:bg-gray-700 rounded w-5/6 animate-pulse" />
        <div className="h-4 bg-gray-200 dark:bg-gray-700 rounded w-4/6 animate-pulse" />
      </div>

      {/* Analysis section skeleton */}
      <div className="space-y-2 mt-6">
        <div className="h-6 bg-gray-200 dark:bg-gray-700 rounded w-1/3 animate-pulse" />
        <div className="h-4 bg-gray-200 dark:bg-gray-700 rounded w-full animate-pulse" />
      </div>
    </div>
  );
}

/**
 * Lazy loaded legal document viewer
 * Xem tài liệu pháp lý được tải lười biếng
 */
export function LazyLegalDocumentViewer({ documentId }: { documentId: string }) {
  return (
    <SuspenseBoundary fallback={<LegalDocumentLoadingFallback />}>
      {/* Lazy loaded component here */}
    </SuspenseBoundary>
  );
}
```

