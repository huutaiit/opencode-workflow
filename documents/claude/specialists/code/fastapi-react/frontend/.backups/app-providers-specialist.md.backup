## Pattern 9.5: ToastProvider
## Mẫu 9.5: ToastProvider

**Purpose**: Toast notifications with Vietnamese localization.
**Mục đích**: Thông báo toast với bản địa hóa Việt Nam.

**File**: `src/app/providers/toast-provider.tsx`

### Implementation / Triển khai

```typescript
'use client';

import { Toaster } from 'react-hot-toast';
import { ReactNode } from 'react';

/**
 * Toast Provider Props
 */
interface ToastProviderProps {
  children: ReactNode;
}

/**
 * Toast Provider Component
 * Component nhà cung cấp thông báo toast
 */
export function ToastProvider({ children }: ToastProviderProps) {
  return (
    <>
      <Toaster
        position="top-right"
        reverseOrder={false}
        toastOptions={{
          duration: 4000,
          style: {
            background: '#fff',
            color: '#000',
            borderRadius: '8px',
            boxShadow: '0 4px 6px rgba(0, 0, 0, 0.1)',
          },
          success: {
            style: {
              background: '#10b981',
              color: '#fff',
            },
            iconTheme: {
              primary: '#fff',
              secondary: '#10b981',
            },
          },
          error: {
            style: {
              background: '#ef4444',
              color: '#fff',
            },
            iconTheme: {
              primary: '#fff',
              secondary: '#ef4444',
            },
          },
          loading: {
            style: {
              background: '#3b82f6',
              color: '#fff',
            },
          },
        }}
      />
      {children}
    </>
  );
}

/**
 * Vietnamese legal toast notifications
 * Thông báo toast pháp lý Việt Nam
 */
import toast from 'react-hot-toast';

export const legalToast = {
  documentUploaded: () => {
    toast.success('Tài liệu đã được tải lên / Document uploaded successfully');
  },

  documentAnalyzed: () => {
    toast.success('Tài liệu đã được phân tích / Document analyzed successfully');
  },

  documentApproved: () => {
    toast.success('Tài liệu được phê duyệt / Document approved');
  },

  complianceCheckPassed: () => {
    toast.success('Kiểm tra tuân thủ thành công / Compliance check passed');
  },

  complianceCheckFailed: (reason: string) => {
    toast.error(`Kiểm tra tuân thủ không thành công: ${reason} / Compliance check failed: ${reason}`);
  },

  contractReviewStarted: () => {
    toast.loading('Đang xem xét hợp đồng... / Reviewing contract...');
  },

  error: (message: string) => {
    toast.error(`Lỗi / Error: ${message}`);
  },

  success: (message: string) => {
    toast.success(`Thành công / Success: ${message}`);
  },

  info: (message: string) => {
    toast((t) => (
      <div>
        <p>{message}</p>
      </div>
    ));
  },
};
