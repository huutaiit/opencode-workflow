## Integration with Backend / Tích hợp với Backend

### FastAPI Backend Integration / Tích hợp Backend FastAPI

```typescript
// API Client Configuration / Cấu hình Client API
import { useAuth } from '@/app/providers/auth-provider';
import { useQueryClient } from '@tanstack/react-query';

const API_BASE_URL = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:8000';

export const apiClient = {
  async request<T>(
    endpoint: string,
    options: RequestInit = {}
  ): Promise<T> {
    const { token } = useAuth();

    const response = await fetch(`${API_BASE_URL}${endpoint}`, {
      headers: {
        'Content-Type': 'application/json',
        ...(token && { Authorization: `Bearer ${token}` }),
        ...options.headers,
      },
      ...options,
    });

    if (!response.ok) {
      if (response.status === 401) {
        // Handle unauthorized - refresh token or logout
        // Xử lý không được phép - làm mới token hoặc đăng xuất
      }
      throw new Error(`API error: ${response.statusText}`);
    }

    return response.json();
  },

  get<T>(endpoint: string) {
    return this.request<T>(endpoint, { method: 'GET' });
  },

  post<T>(endpoint: string, data: unknown) {
    return this.request<T>(endpoint, {
      method: 'POST',
      body: JSON.stringify(data),
    });
  },

  put<T>(endpoint: string, data: unknown) {
    return this.request<T>(endpoint, {
      method: 'PUT',
      body: JSON.stringify(data),
    });
  },

  delete<T>(endpoint: string) {
    return this.request<T>(endpoint, { method: 'DELETE' });
  },
};

// Vietnamese Legal API Methods / Các phương thức API pháp lý Việt Nam
export const legalApi = {
  // Users / Người dùng
  users: {
    getAll: () => apiClient.get('/api/v1/users'),
    getById: (id: string) => apiClient.get(`/api/v1/users/${id}`),
    create: (data: any) => apiClient.post('/api/v1/users', data),
    update: (id: string, data: any) => apiClient.put(`/api/v1/users/${id}`, data),
  },

  // Legal Documents / Tài liệu pháp lý
  documents: {
    getAll: () => apiClient.get('/api/v1/documents'),
    getById: (id: string) => apiClient.get(`/api/v1/documents/${id}`),
    upload: (formData: FormData) =>
      fetch(`${API_BASE_URL}/api/v1/documents/upload`, {
        method: 'POST',
        body: formData,
      }),
    analyze: (id: string) => apiClient.post(`/api/v1/documents/${id}/analyze`, {}),
  },

  // Conversations / Cuộc hội thoại
  conversations: {
    getAll: () => apiClient.get('/api/v1/conversations'),
    getById: (id: string) => apiClient.get(`/api/v1/conversations/${id}`),
    create: (data: any) => apiClient.post('/api/v1/conversations', data),
    sendMessage: (conversationId: string, message: string) =>
      apiClient.post(`/api/v1/conversations/${conversationId}/messages`, {
        content: message,
      }),
  },

  // Compliance / Tuân thủ
  compliance: {
    check: (documentId: string) =>
      apiClient.post(`/api/v1/documents/${documentId}/compliance-check`, {}),
  },
};
```

