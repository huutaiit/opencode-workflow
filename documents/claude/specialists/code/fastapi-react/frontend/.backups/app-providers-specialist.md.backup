## Pattern 9.1: QueryProvider (TanStack Query v5)
## Mẫu 9.1: QueryProvider (TanStack Query v5)

**Purpose**: Global React Query configuration with optimized defaults.
**Mục đích**: Cấu hình React Query toàn cục với các giá trị mặc định được tối ưu hóa.

**File**: `src/app/providers/query-provider.tsx`

### Implementation / Triển khai

```typescript
'use client';

import { QueryClient, QueryClientProvider } from '@tanstack/react-query';
import { ReactQueryDevtools } from '@tanstack/react-query-devtools';
import { useState, type ReactNode } from 'react';

/**
 * Query Provider Props / Các tham số Query Provider
 */
interface QueryProviderProps {
  children: ReactNode;
}

/**
 * Create Query Client with optimized defaults
 * Tạo Query Client với các giá trị mặc định được tối ưu hóa
 */
const createQueryClient = () => {
  return new QueryClient({
    defaultOptions: {
      queries: {
        // Stale time: 5 minutes - data considered fresh for 5 min
        // Thời gian hết hạn: 5 phút - dữ liệu được coi là tươi trong 5 phút
        staleTime: 5 * 60 * 1000,

        // Cache time: 10 minutes - keep data in cache for 10 min
        // Thời gian lưu trong bộ nhớ đệm: 10 phút - giữ dữ liệu trong bộ nhớ đệm 10 phút
        gcTime: 10 * 60 * 1000,

        // Retry failed requests 3 times with exponential backoff
        // Thử lại các yêu cầu không thành công 3 lần với tăng số mũ
        retry: 3,
        retryDelay: (attemptIndex) => Math.min(1000 * 2 ** attemptIndex, 30000),

        // Refetch on window focus in production environment
        // Tái tìm nạp khi cửa sổ được focus trong môi trường sản xuất
        refetchOnWindowFocus: process.env.NODE_ENV === 'production',

        // Refetch when network reconnects
        // Tái tìm nạp khi mạng kết nối lại
        refetchOnReconnect: true,

        // Refetch on mount only if data is stale
        // Tái tìm nạp khi tải chỉ nếu dữ liệu hết hạn
        refetchOnMount: 'stale',

        // Throw error on query failure
        // Ném lỗi khi truy vấn không thành công
        throwOnError: false,
      },
      mutations: {
        // Retry mutations once on failure
        // Thử lại các đột biến một lần khi thất bại
        retry: 1,

        // Show error toasts on mutation failure
        // Hiển thị thông báo lỗi khi đột biến không thành công
        onError: (error) => {
          console.error('Mutation failed:', error);
          // Toast notification handled by ToastProvider
        },
      },
    },
  });
};

/**
 * QueryProvider Component
 * Component QueryProvider
 */
export function QueryProvider({ children }: QueryProviderProps) {
  // Create query client once per component mount
  // Tạo query client một lần cho mỗi lần tải component
  const [queryClient] = useState(() => createQueryClient());

  return (
    <QueryClientProvider client={queryClient}>
      {children}
      {/* Show DevTools only in development */}
      {/* Chỉ hiển thị DevTools trong môi trường phát triển */}
      {process.env.NODE_ENV === 'development' && (
        <ReactQueryDevtools
          initialIsOpen={false}
          position="bottom-right"
          buttonPosition="bottom-right"
        />
      )}
    </QueryClientProvider>
  );
}

/**
 * Query configuration hook
 * Hook cấu hình truy vấn
 */
export const useQueryConfig = () => {
  return {
    staleTime: 5 * 60 * 1000,
    gcTime: 10 * 60 * 1000,
    retry: 3,
  };
};

/**
 * Pre-configured query keys for type safety
 * Các khóa truy vấn được cấu hình trước để có tính an toàn kiểu
 * Áp dụng cho nền tảng pháp lý và CRM
 */
export const queryKeys = {
  // Authentication queries / Các truy vấn xác thực
  auth: {
    user: () => ['auth', 'user'] as const,
    session: () => ['auth', 'session'] as const,
    profile: () => ['auth', 'profile'] as const,
  },

  // User management queries / Các truy vấn quản lý người dùng
  users: {
    all: () => ['users'] as const,
    lists: () => ['users', 'list'] as const,
    list: (filters: Record<string, unknown>) => ['users', 'list', filters] as const,
    details: () => ['users', 'detail'] as const,
    detail: (id: string) => ['users', 'detail', id] as const,
    role: (role: string) => ['users', 'role', role] as const,
  },

  // Legal documents / Các tài liệu pháp lý
  documents: {
    all: () => ['documents'] as const,
    lists: () => ['documents', 'list'] as const,
    list: (filters: Record<string, unknown>) => ['documents', 'list', filters] as const,
    detail: (id: string) => ['documents', 'detail', id] as const,
    analysis: (id: string) => ['documents', 'analysis', id] as const,
  },

  // Conversations and chat / Các cuộc hội thoại và trò chuyện
  conversations: {
    all: () => ['conversations'] as const,
    lists: () => ['conversations', 'list'] as const,
    list: (filters: Record<string, unknown>) => ['conversations', 'list', filters] as const,
    detail: (id: string) => ['conversations', 'detail', id] as const,
    messages: (conversationId: string) => ['conversations', conversationId, 'messages'] as const,
    legal: (conversationId: string) => ['conversations', conversationId, 'legal'] as const,
  },

  // AI Analysis / Phân tích AI
  analysis: {
    all: () => ['analysis'] as const,
    detail: (id: string) => ['analysis', 'detail', id] as const,
    legal: (documentId: string) => ['analysis', 'legal', documentId] as const,
  },

  // Contracts / Hợp đồng
  contracts: {
    all: () => ['contracts'] as const,
    lists: () => ['contracts', 'list'] as const,
    list: (filters: Record<string, unknown>) => ['contracts', 'list', filters] as const,
    detail: (id: string) => ['contracts', 'detail', id] as const,
    templates: () => ['contracts', 'templates'] as const,
  },

  // Compliance checks / Kiểm tra tuân thủ
  compliance: {
    all: () => ['compliance'] as const,
    check: (documentId: string) => ['compliance', 'check', documentId] as const,
    history: (documentId: string) => ['compliance', 'history', documentId] as const,
  },
} as const;

/**
 * Custom hook for querying users with legal role filter
 * Hook tùy chỉnh để truy vấn người dùng với bộ lọc vai trò pháp lý
 */
export const useUserQuery = (userId: string) => {
  return {
    queryKey: queryKeys.users.detail(userId),
    queryFn: async () => {
      // API call would be made here
      // Cuộc gọi API sẽ được thực hiện ở đây
    },
  };
};

/**
 * Custom hook for legal document queries
 * Hook tùy chỉnh cho các truy vấn tài liệu pháp lý
 */
export const useLegalDocumentQuery = (documentId: string) => {
  return {
    queryKey: queryKeys.documents.detail(documentId),
    queryFn: async () => {
      // Fetch legal document with analysis
      // Lấy tài liệu pháp lý cùng với phân tích
    },
  };
};
```

### Usage Examples / Ví dụ sử dụng

```typescript
'use client';

import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { queryKeys } from '@/app/providers/query-provider';
import { userApi } from '@/shared/api/user';
import { documentsApi } from '@/shared/api/documents';

/**
 * Vietnamese legal user management hook
 * Hook quản lý người dùng pháp lý Việt Nam
 */
export function useUserDetails(userId: string) {
  return useQuery({
    queryKey: queryKeys.users.detail(userId),
    queryFn: () => userApi.getById(userId),
    enabled: !!userId,
    staleTime: 5 * 60 * 1000, // 5 minutes
  });
}

/**
 * Vietnamese legal document analysis hook
 * Hook phân tích tài liệu pháp lý Việt Nam
 */
export function useLegalDocumentAnalysis(documentId: string) {
  return useQuery({
    queryKey: queryKeys.documents.analysis(documentId),
    queryFn: () => documentsApi.analyze(documentId),
    enabled: !!documentId,
    staleTime: 10 * 60 * 1000, // 10 minutes for analysis
  });
}

/**
 * Mutation hook for updating user profile
 * Hook đột biến để cập nhật hồ sơ người dùng
 */
export function useUpdateUserProfile() {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn: userApi.updateProfile,
    onMutate: async (variables) => {
      // Cancel outgoing queries
      await queryClient.cancelQueries({
        queryKey: queryKeys.users.detail(variables.id),
      });

      // Snapshot previous value
      const previousUser = queryClient.getQueryData(
        queryKeys.users.detail(variables.id)
      );

      // Optimistically update
      queryClient.setQueryData(queryKeys.users.detail(variables.id), variables);

      return { previousUser };
    },
    onError: (err, variables, context) => {
      // Rollback on error
      if (context?.previousUser) {
        queryClient.setQueryData(
          queryKeys.users.detail(variables.id),
          context.previousUser
        );
      }
    },
    onSuccess: (data, variables) => {
      // Invalidate and refetch
      queryClient.invalidateQueries({
        queryKey: queryKeys.users.detail(variables.id),
      });
      queryClient.invalidateQueries({
        queryKey: queryKeys.users.lists(),
      });
    },
  });
}

/**
 * Mutation hook for analyzing legal documents
 * Hook đột biến để phân tích tài liệu pháp lý
 */
export function useAnalyzeLegalDocument() {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn: documentsApi.analyze,
    onSuccess: (data, variables) => {
      // Invalidate document detail query
      queryClient.invalidateQueries({
        queryKey: queryKeys.documents.detail(variables.documentId),
      });
      queryClient.invalidateQueries({
        queryKey: queryKeys.documents.analysis(variables.documentId),
      });
    },
  });
}

/**
 * Conversation messages hook with Vietnamese context
 * Hook các tin nhắn cuộc hội thoại với bối cảnh Việt Nam
 */
export function useConversationMessages(conversationId: string) {
  return useQuery({
    queryKey: queryKeys.conversations.messages(conversationId),
    queryFn: () => documentsApi.getMessages(conversationId),
    enabled: !!conversationId,
    refetchInterval: 3000, // Poll every 3 seconds for real-time updates
  });
}
```

