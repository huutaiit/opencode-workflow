## Pattern 9.20: OptimizationProvider
## Mẫu 9.20: OptimizationProvider

**Purpose**: Performance optimization utilities and configuration.
**Mục đích**: Tiện ích tối ưu hóa hiệu suất và cấu hình.

**File**: `src/app/providers/optimization-provider.tsx`

### Implementation / Triển khai

```typescript
'use client';

import { ReactNode, useEffect } from 'react';

/**
 * Optimization Provider Props
 */
interface OptimizationProviderProps {
  children: ReactNode;
}

/**
 * Optimization Provider Component
 * Component nhà cung cấp tối ưu hóa
 */
export function OptimizationProvider({ children }: OptimizationProviderProps) {
  useEffect(() => {
    // Preload critical resources
    // Tải trước các tài nguyên quan trọng
    const preloadLinks = [
      { rel: 'prefetch', href: '/api/auth/user', as: 'fetch' },
      { rel: 'prefetch', href: '/api/documents', as: 'fetch' },
    ];

    preloadLinks.forEach((link) => {
      const element = document.createElement('link');
      element.rel = link.rel;
      element.href = link.href;
      if (link.as) element.as = link.as as any;
      document.head.appendChild(element);
    });

    // Enable performance monitoring
    // Kích hoạt giám sát hiệu suất
    if ('PerformanceObserver' in window) {
      try {
        const observer = new PerformanceObserver((list) => {
          for (const entry of list.getEntries()) {
            if (entry.duration > 3000) {
              console.warn(`Slow operation: ${entry.name} took ${entry.duration}ms`);
            }
          }
        });

        observer.observe({ entryTypes: ['measure', 'navigation'] });

        return () => observer.disconnect();
      } catch (e) {
        console.error('Performance monitoring failed:', e);
      }
    }
  }, []);

  return <>{children}</>;
}

/**
 * Performance monitoring hook
 * Hook giám sát hiệu suất
 */
export function usePerformanceMonitoring(operationName: string) {
  useEffect(() => {
    const startTime = performance.now();

    return () => {
      const endTime = performance.now();
      const duration = endTime - startTime;

      if (duration > 1000) {
        console.warn(`Performance: ${operationName} took ${duration}ms`);
      }

      // Send to analytics
      if (typeof window !== 'undefined' && (window as any).gtag) {
        (window as any).gtag('event', 'performance', {
          operation: operationName,
          duration,
        });
      }
    };
  }, [operationName]);
}

/**
 * Image optimization helper
 * Trợ giúp tối ưu hóa hình ảnh
 */
export function OptimizedImage({
  src,
  alt,
  width,
  height,
  priority = false,
}: {
  src: string;
  alt: string;
  width: number;
  height: number;
  priority?: boolean;
}) {
  return (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      className="image-optimize"
    />
  );
}
```

