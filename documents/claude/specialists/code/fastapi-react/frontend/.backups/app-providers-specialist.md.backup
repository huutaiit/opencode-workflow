## Pattern 9.4: I18nProvider
## Mẫu 9.4: I18nProvider

**Purpose**: Internationalization (Vietnamese/English) for legal platform.
**Mục đích**: Quốc tế hóa (Tiếng Việt / Tiếng Anh) cho nền tảng pháp lý.

**File**: `src/app/providers/i18n-provider.tsx`

### Implementation / Triển khai

```typescript
'use client';

import { useEffect, ReactNode } from 'react';
import { useUIStore } from './store-provider';

/**
 * Vietnamese legal terminology dictionary
 * Từ điển chuyên ngành pháp lý Việt Nam
 */
export const i18n = {
  vi: {
    // Navigation
    dashboard: 'Bảng điều khiển',
    documents: 'Tài liệu pháp lý',
    conversations: 'Cuộc hội thoại',
    users: 'Người dùng',
    settings: 'Cài đặt',

    // Legal terms
    contract: 'Hợp đồng',
    agreement: 'Thỏa thuận',
    legal_document: 'Tài liệu pháp lý',
    compliance: 'Tuân thủ pháp luật',
    review: 'Xem xét',
    analysis: 'Phân tích',
    summary: 'Tóm tắt',

    // Actions
    upload: 'Tải lên',
    download: 'Tải xuống',
    analyze: 'Phân tích',
    share: 'Chia sẻ',
    delete: 'Xóa',
    save: 'Lưu',
    cancel: 'Hủy bỏ',
    submit: 'Gửi',

    // Status
    pending: 'Đang chờ',
    approved: 'Được phê duyệt',
    rejected: 'Bị từ chối',
    processing: 'Đang xử lý',
    completed: 'Hoàn thành',

    // Errors
    error: 'Lỗi',
    error_occurred: 'Đã xảy ra lỗi',
    try_again: 'Thử lại',
    server_error: 'Lỗi máy chủ',
    network_error: 'Lỗi mạng',
  },
  en: {
    // Navigation
    dashboard: 'Dashboard',
    documents: 'Legal Documents',
    conversations: 'Conversations',
    users: 'Users',
    settings: 'Settings',

    // Legal terms
    contract: 'Contract',
    agreement: 'Agreement',
    legal_document: 'Legal Document',
    compliance: 'Compliance',
    review: 'Review',
    analysis: 'Analysis',
    summary: 'Summary',

    // Actions
    upload: 'Upload',
    download: 'Download',
    analyze: 'Analyze',
    share: 'Share',
    delete: 'Delete',
    save: 'Save',
    cancel: 'Cancel',
    submit: 'Submit',

    // Status
    pending: 'Pending',
    approved: 'Approved',
    rejected: 'Rejected',
    processing: 'Processing',
    completed: 'Completed',

    // Errors
    error: 'Error',
    error_occurred: 'An error occurred',
    try_again: 'Try again',
    server_error: 'Server error',
    network_error: 'Network error',
  },
} as const;

export type Language = keyof typeof i18n;

/**
 * I18n Provider Props
 */
interface I18nProviderProps {
  children: ReactNode;
}

/**
 * I18n Provider Component
 * Component nhà cung cấp quốc tế hóa
 */
export function I18nProvider({ children }: I18nProviderProps) {
  const { language, setLanguage } = useUIStore();

  useEffect(() => {
    // Set HTML lang attribute
    document.documentElement.lang = language;
  }, [language]);

  return <>{children}</>;
}

/**
 * Hook to use translations
 * Hook sử dụng bản dịch
 */
import { useUIStore } from './store-provider';

export function useTranslation() {
  const { language } = useUIStore();

  return {
    language,
    t: (key: keyof (typeof i18n)[Language]) => {
      const currentLanguage = language as Language;
      return i18n[currentLanguage][key] || key;
    },
    // Get specific language translation
    tByLang: (lang: Language, key: keyof (typeof i18n)[Language]) => {
      return i18n[lang][key] || key;
    },
  };
}

/**
 * Vietnamese legal document status translations
 * Bản dịch trạng thái tài liệu pháp lý Việt Nam
 */
export const documentStatusTranslations = {
  vi: {
    draft: 'Bản nháp',
    submitted: 'Đã gửi',
    under_review: 'Đang xem xét',
    approved: 'Được phê duyệt',
    rejected: 'Bị từ chối',
    archived: 'Lưu trữ',
  },
  en: {
    draft: 'Draft',
    submitted: 'Submitted',
    under_review: 'Under Review',
    approved: 'Approved',
    rejected: 'Rejected',
    archived: 'Archived',
  },
} as const;
