## Provider Composition Pattern / Mẫu Sáng tác Nhà cung cấp

**File**: `src/app/providers.tsx`

### Implementation / Triển khai

```typescript
'use client';

import { ReactNode } from 'react';
import { QueryProvider } from './providers/query-provider';
import { AppThemeProvider } from './providers/theme-provider';
import { AuthProvider } from './providers/auth-provider';
import { ToastProvider } from './providers/toast-provider';
import { I18nProvider } from './providers/i18n-provider';
import { ErrorBoundary } from './providers/error-boundary';
import { OptimizationProvider } from './providers/optimization-provider';

/**
 * Combined Providers Props
 */
interface ProvidersProps {
  children: ReactNode;
}

/**
 * Root Providers Component
 * Component nhà cung cấp gốc
 *
 * Provider order is critical:
 * 1. ErrorBoundary - wraps everything
 * 2. OptimizationProvider - performance setup
 * 3. QueryProvider - server state (TanStack Query)
 * 4. AppThemeProvider - theme setup (early for UI)
 * 5. I18nProvider - internationalization
 * 6. AuthProvider - authentication context
 * 7. ToastProvider - notifications
 *
 * Thứ tự nhà cung cấp rất quan trọng:
 * 1. ErrorBoundary - bao bọc mọi thứ
 * 2. OptimizationProvider - cấu hình hiệu suất
 * 3. QueryProvider - trạng thái máy chủ (TanStack Query)
 * 4. AppThemeProvider - cấu hình chủ đề (sớm cho giao diện)
 * 5. I18nProvider - quốc tế hóa
 * 6. AuthProvider - bối cảnh xác thực
 * 7. ToastProvider - thông báo
 */
export function Providers({ children }: ProvidersProps) {
  return (
    <ErrorBoundary
      onError={(error, errorInfo) => {
        console.error('Global error caught:', error, errorInfo);
        // Send to error tracking service
      }}
    >
      <OptimizationProvider>
        <QueryProvider>
          <AppThemeProvider>
            <I18nProvider>
              <AuthProvider>
                <ToastProvider>{children}</ToastProvider>
              </AuthProvider>
            </I18nProvider>
          </AppThemeProvider>
        </QueryProvider>
      </OptimizationProvider>
    </ErrorBoundary>
  );
}

/**
 * Usage in root layout
 * Sử dụng trong bố cục gốc
 *
 * File: src/app/layout.tsx
 */
export const RootLayoutExample = `
import type { Metadata } from 'next';
import { Providers } from './providers';
import './globals.css';

export const metadata: Metadata = {
  title: 'StarX4CRM - AI-Powered Legal Platform',
  description: 'Vietnamese legal AI platform with multi-agent system',
  keywords: ['Legal', 'AI', 'CRM', 'Vietnamese'],
};

export default function RootLayout({
  children,
}: {
  children: React.ReactNode;
}) {
  return (
    <html lang="en" suppressHydrationWarning>
      <body>
        <Providers>{children}</Providers>
      </body>
    </html>
  );
}
`;
```

