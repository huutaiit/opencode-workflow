## Pattern 9.6: StoreProvider (Zustand)
## Mẫu 9.6: StoreProvider (Zustand)

**Purpose**: Global state management with Zustand and persistence.
**Mục đích**: Quản lý trạng thái toàn cục với Zustand và sự tồn tại.

**File**: `src/app/providers/store-provider.tsx`

### Implementation / Triển khai

```typescript
'use client';

import { create } from 'zustand';
import { persist, createJSONStorage } from 'zustand/middleware';
import { devtools } from 'zustand/middleware';
import { immer } from 'zustand/middleware/immer';

/**
 * Auth Store / Cửa hàng xác thực
 */
export interface AuthState {
  user: any | null;
  token: string | null;
  isAuthenticated: boolean;
  setUser: (user: any | null) => void;
  setToken: (token: string | null) => void;
  logout: () => void;
}

export const useAuthStore = create<AuthState>()(
  devtools(
    persist(
      immer((set) => ({
        user: null,
        token: null,
        isAuthenticated: false,

        setUser: (user) =>
          set((state) => {
            state.user = user;
            state.isAuthenticated = !!user;
          }),

        setToken: (token) =>
          set((state) => {
            state.token = token;
          }),

        logout: () =>
          set((state) => {
            state.user = null;
            state.token = null;
            state.isAuthenticated = false;
          }),
      })),
      {
        name: 'auth-storage',
        storage: createJSONStorage(() => localStorage),
        partialize: (state) => ({
          token: state.token,
          user: state.user,
        }),
      }
    ),
    { name: 'AuthStore' }
  )
);

/**
 * UI Store / Cửa hàng giao diện người dùng
 */
export interface UIState {
  sidebarOpen: boolean;
  theme: 'light' | 'dark' | 'system';
  language: 'vi' | 'en';
  setSidebarOpen: (open: boolean) => void;
  toggleSidebar: () => void;
  setTheme: (theme: 'light' | 'dark' | 'system') => void;
  setLanguage: (language: 'vi' | 'en') => void;
}

export const useUIStore = create<UIState>()(
  devtools(
    persist(
      immer((set) => ({
        sidebarOpen: true,
        theme: 'system',
        language: 'vi', // Default to Vietnamese for legal platform

        setSidebarOpen: (open) =>
          set((state) => {
            state.sidebarOpen = open;
          }),

        toggleSidebar: () =>
          set((state) => {
            state.sidebarOpen = !state.sidebarOpen;
          }),

        setTheme: (theme) =>
          set((state) => {
            state.theme = theme;
          }),

        setLanguage: (language) =>
          set((state) => {
            state.language = language;
          }),
      })),
      {
        name: 'ui-storage',
        storage: createJSONStorage(() => localStorage),
      }
    ),
    { name: 'UIStore' }
  )
);

/**
 * Conversation Store / Cửa hàng cuộc hội thoại
 * Vietnamese legal conversation management
 */
export interface ConversationState {
  currentConversationId: string | null;
  conversations: any[];
  setCurrentConversation: (id: string | null) => void;
  addConversation: (conversation: any) => void;
  updateConversation: (id: string, updates: any) => void;
  removeConversation: (id: string) => void;
}

export const useConversationStore = create<ConversationState>()(
  devtools(
    immer((set) => ({
      currentConversationId: null,
      conversations: [],

      setCurrentConversation: (id) =>
        set((state) => {
          state.currentConversationId = id;
        }),

      addConversation: (conversation) =>
        set((state) => {
          state.conversations.push(conversation);
        }),

      updateConversation: (id, updates) =>
        set((state) => {
          const conversation = state.conversations.find((c) => c.id === id);
          if (conversation) {
            Object.assign(conversation, updates);
          }
        }),

      removeConversation: (id) =>
        set((state) => {
          state.conversations = state.conversations.filter((c) => c.id !== id);
          if (state.currentConversationId === id) {
            state.currentConversationId = null;
          }
        }),
    })),
    { name: 'ConversationStore' }
  )
);

/**
 * Document Store / Cửa hàng tài liệu
 * Vietnamese legal document management
 */
export interface DocumentState {
  selectedDocumentId: string | null;
  documents: any[];
  analysisResults: Record<string, any>;
  setSelectedDocument: (id: string | null) => void;
  addDocument: (document: any) => void;
  setAnalysisResult: (documentId: string, result: any) => void;
}

export const useDocumentStore = create<DocumentState>()(
  devtools(
    immer((set) => ({
      selectedDocumentId: null,
      documents: [],
      analysisResults: {},

      setSelectedDocument: (id) =>
        set((state) => {
          state.selectedDocumentId = id;
        }),

      addDocument: (document) =>
        set((state) => {
          state.documents.push(document);
        }),

      setAnalysisResult: (documentId, result) =>
        set((state) => {
          state.analysisResults[documentId] = result;
        }),
    })),
    { name: 'DocumentStore' }
  )
);

/**
 * Combined Provider Component
 * Component nhà cung cấp kết hợp
 */
export function StoreProvider({ children }: { children: React.ReactNode }) {
  return <>{children}</>;
}
```

