## Pattern 9.2: ThemeProvider (next-themes)
## Mẫu 9.2: ThemeProvider (next-themes)

**Purpose**: Next-themes integration for light/dark/system theme switching.
**Mục đích**: Tích hợp next-themes cho chuyển đổi chủ đề sáng/tối/hệ thống.

**File**: `src/app/providers/theme-provider.tsx`

### Implementation / Triển khai

```typescript
'use client';

import { ThemeProvider } from 'next-themes';
import { ReactNode } from 'react';

/**
 * Theme Provider Props
 * Các tham số Theme Provider
 */
interface ThemeProviderProps {
  children: ReactNode;
}

/**
 * Theme Provider Component
 * Component Theme Provider
 */
export function AppThemeProvider({ children }: ThemeProviderProps) {
  return (
    <ThemeProvider
      attribute="class"
      defaultTheme="system"
      enableSystem
      enableColorScheme
      disableTransitionOnChange
      storageKey="app-theme"
    >
      {children}
    </ThemeProvider>
  );
}

/**
 * Hook to use theme
 * Hook sử dụng chủ đề
 */
import { useTheme } from 'next-themes';

export function useAppTheme() {
  const { theme, setTheme, themes, systemTheme } = useTheme();

  return {
    theme,
    setTheme,
    themes,
    systemTheme,
    isDark: theme === 'dark' || (theme === 'system' && systemTheme === 'dark'),
  };
}

/**
 * Vietnamese theme configuration for legal platform
 * Cấu hình chủ đề Việt Nam cho nền tảng pháp lý
 */
export const themeConfig = {
  light: {
    name: 'Ánh sáng / Light',
    primary: 'hsl(217, 91%, 60%)', // Blue for legal documents
    background: 'hsl(0, 0%, 100%)',
    foreground: 'hsl(217, 33%, 17%)',
  },
  dark: {
    name: 'Tối / Dark',
    primary: 'hsl(217, 91%, 60%)',
    background: 'hsl(217, 39%, 11%)',
    foreground: 'hsl(210, 40%, 96%)',
  },
} as const;
```

### Usage in CSS / Sử dụng trong CSS

```css
/* tailwind.config.ts */
export default {
  darkMode: 'class',
  theme: {
    extend: {
      colors: {
        /* Legal platform colors - Các màu nền tảng pháp lý */
        legal: {
          primary: 'hsl(217, 91%, 60%)',
          secondary: 'hsl(262, 80%, 50%)',
          accent: 'hsl(262, 80%, 50%)',
          danger: 'hsl(0, 84%, 60%)',
          success: 'hsl(142, 71%, 45%)',
          warning: 'hsl(38, 92%, 50%)',
        },
      },
    },
  },
};

/* HTML with theme attribute */
<html class="dark"> {/* or 'light' */}
  <body className="bg-white dark:bg-slate-950">
    {/* Content */}
  </body>
</html>
```

