## IV. VIETNAMESE LEGAL DOMAIN CONTEXT

### Domain Models

```typescript
// Core legal domain entities
interface Case {
  id: string;
  case_number: string; // VN case numbering format
  title: string;
  type: 'civil' | 'commercial' | 'criminal' | 'administrative';
  status: 'active' | 'pending' | 'closed' | 'archived';
  priority: 'high' | 'medium' | 'low';
  created_at: Date;
  assigned_to?: User;
  clients: Client[];
  documents: Document[];
  related_cases?: Case[];
  deadlines: Deadline[];
}

interface Client {
  id: string;
  name: string;
  type: 'individual' | 'organization';
  tax_id?: string; // Mã số thuế
  phone: string;
  email: string;
  address: string;
}

interface Document {
  id: string;
  case_id: string;
  title: string;
  type: 'contract' | 'evidence' | 'submission' | 'court_order';
  file_url: string;
  uploaded_by: User;
  created_at: Date;
  version: number;
}

interface Deadline {
  id: string;
  case_id: string;
  title: string;
  due_date: Date;
  type: 'court_submission' | 'payment' | 'response' | 'evidence';
  status: 'pending' | 'completed' | 'overdue';
  assigned_to?: User;
}

interface Conversation {
  id: string;
  participants: User[];
  case_id?: string;
  title: string;
  created_at: Date;
  updated_at: Date;
  messages: Message[];
}

interface Message {
  id: string;
  conversation_id: string;
  sender_id: string;
  content: string;
  attachments?: Attachment[];
  created_at: Date;
}
```

