### Pattern 10.6: Dashboard Home Page (Protected)

**Purpose**: Main dashboard with overview widgets and real-time data

**File**: `src/app/(dashboard)/page.tsx`

**Complete Implementation**:

```typescript
import { Metadata } from 'next';
import { Suspense } from 'react';
import { notFound, redirect } from 'next/navigation';
import { getAuthSession } from '@/shared/auth/get-session';
import { StatsWidget } from '@/widgets/dashboard/stats-widget';
import { RecentCasesWidget } from '@/widgets/dashboard/recent-cases-widget';
import { UpcomingDeadlinesWidget } from '@/widgets/dashboard/upcoming-deadlines-widget';
import { ConversationsWidget } from '@/widgets/dashboard/conversations-widget';
import { DocumentsWidget } from '@/widgets/dashboard/documents-widget';
import { WidgetSkeleton } from '@/shared/ui/skeletons/widget-skeleton';

export const metadata: Metadata = {
  title: 'Dashboard - StarX4CRM',
  description: 'Tổng quan quản lý vụ việc, hợp đồng và khách hàng',
  robots: {
    index: false, // Protect dashboard from search indexing
    follow: false,
  },
};

interface DashboardPageProps {
  searchParams: {
    date_range?: string;
    status?: string;
  };
}

// Server-side data fetching functions
async function getStatsData(userId: string) {
  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/dashboard/stats`,
    {
      headers: {
        'Authorization': `Bearer ${process.env.INTERNAL_API_TOKEN}`,
        'X-User-ID': userId,
      },
      cache: 'no-store', // Always fresh for dashboard
      next: { tags: ['dashboard-stats'] },
    }
  );

  if (!res.ok) {
    throw new Error('Failed to fetch dashboard stats');
  }

  return res.json();
}

async function getRecentCases(userId: string, searchParams: DashboardPageProps['searchParams']) {
  const params = new URLSearchParams();
  if (searchParams.date_range) {
    params.set('date_range', searchParams.date_range);
  }
  if (searchParams.status) {
    params.set('status', searchParams.status);
  }

  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/cases/recent?${params.toString()}`,
    {
      headers: {
        'Authorization': `Bearer ${process.env.INTERNAL_API_TOKEN}`,
        'X-User-ID': userId,
      },
      next: { revalidate: 60 }, // Revalidate every minute
      next: { tags: ['cases-recent'] },
    }
  );

  if (!res.ok) {
    throw new Error('Failed to fetch recent cases');
  }

  return res.json();
}

async function getUpcomingDeadlines(userId: string) {
  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/deadlines/upcoming`,
    {
      headers: {
        'Authorization': `Bearer ${process.env.INTERNAL_API_TOKEN}`,
        'X-User-ID': userId,
      },
      next: { revalidate: 300 }, // Revalidate every 5 minutes
    }
  );

  if (!res.ok) {
    throw new Error('Failed to fetch deadlines');
  }

  return res.json();
}

export default async function DashboardPage({
  searchParams,
}: DashboardPageProps) {
  // Authentication check
  const session = await getAuthSession();
  if (!session?.user) {
    redirect('/login?callbackUrl=/dashboard');
  }

  const userId = session.user.id;

  // Parallel data fetching for performance
  const [stats, cases, deadlines] = await Promise.all([
    getStatsData(userId),
    getRecentCases(userId, searchParams),
    getUpcomingDeadlines(userId),
  ]);

  return (
    <div className="min-h-screen bg-gray-50 p-6 space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-3xl font-bold text-gray-900">
            Xin chào, {session.user.name}
          </h1>
          <p className="text-gray-600 mt-1">
            Tổng quan hoạt động của bạn hôm nay
          </p>
        </div>
      </div>

      {/* Stats Grid - 4 Columns */}
      <div className="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        <Suspense fallback={<WidgetSkeleton />}>
          <StatsWidget
            label="Vụ Việc Hoạt Động"
            value={stats.active_cases}
            change={stats.cases_change}
            icon="briefcase"
          />
        </Suspense>
        <Suspense fallback={<WidgetSkeleton />}>
          <StatsWidget
            label="Hợp Đồng Sắp Hết Hạn"
            value={stats.expiring_contracts}
            change={stats.contracts_change}
            icon="document"
          />
        </Suspense>
        <Suspense fallback={<WidgetSkeleton />}>
          <StatsWidget
            label="Khách Hàng Mới"
            value={stats.new_clients}
            change={stats.clients_change}
            icon="users"
          />
        </Suspense>
        <Suspense fallback={<WidgetSkeleton />}>
          <StatsWidget
            label="Tin Nhắn Chưa Đọc"
            value={stats.unread_messages}
            change={0}
            icon="message"
          />
        </Suspense>
      </div>

      {/* Main Content Grid - 2 Rows */}
      <div className="grid gap-6 lg:grid-cols-2">
        {/* Recent Cases */}
        <Suspense fallback={<WidgetSkeleton className="h-96" />}>
          <div className="bg-white rounded-lg shadow-md p-6">
            <h2 className="text-xl font-bold text-gray-900 mb-4">
              Vụ Việc Gần Đây
            </h2>
            <RecentCasesWidget cases={cases} />
          </div>
        </Suspense>

        {/* Upcoming Deadlines */}
        <Suspense fallback={<WidgetSkeleton className="h-96" />}>
          <div className="bg-white rounded-lg shadow-md p-6">
            <h2 className="text-xl font-bold text-gray-900 mb-4">
              Thời Hạn Sắp Tới
            </h2>
            <UpcomingDeadlinesWidget deadlines={deadlines} />
          </div>
        </Suspense>
      </div>

      {/* Secondary Content */}
      <div className="grid gap-6 lg:grid-cols-3">
        <Suspense fallback={<WidgetSkeleton className="h-96" />}>
          <div className="lg:col-span-2 bg-white rounded-lg shadow-md p-6">
            <h2 className="text-xl font-bold text-gray-900 mb-4">
              Hoạt Động Gần Đây
            </h2>
            <ConversationsWidget userId={userId} />
          </div>
        </Suspense>

        <Suspense fallback={<WidgetSkeleton className="h-96" />}>
          <div className="bg-white rounded-lg shadow-md p-6">
            <h2 className="text-xl font-bold text-gray-900 mb-4">
              Tài Liệu Nổi Bật
            </h2>
            <DocumentsWidget userId={userId} />
          </div>
        </Suspense>
      </div>
    </div>
  );
}
```

**Data Fetching Strategies**:

```typescript
// 1. Always Fresh (Real-time data)
{ cache: 'no-store' }

// 2. Incremental Static Regeneration
{ next: { revalidate: 60 } }

// 3. Tag-Based Revalidation
{ next: { tags: ['dashboard-stats'] } }
// Then in Server Action:
// revalidateTag('dashboard-stats');

// 4. Static Generation (Cached Forever)
{ cache: 'force-cache' }
```

**Technology Notes**:
- Server Component with async authentication
- Parallel data fetching with `Promise.all()`
- Suspense boundaries for progressive rendering
- Tag-based cache invalidation
- Vietnamese labels for legal domain

**Best Practices**:
- Authentication check before rendering
- Parallel data fetching for performance
- Suspense for non-blocking UI
- Appropriate cache strategies per widget
- Responsive grid layouts

