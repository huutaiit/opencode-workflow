### Pattern 10.11: User/Case List Page (CRUD)

**Purpose**: CRUD management page with list, search, filters, and pagination

**File**: `src/app/(dashboard)/cases/page.tsx`

**Complete Implementation**:

```typescript
import { Metadata } from 'next';
import { Suspense } from 'react';
import { getAuthSession } from '@/shared/auth/get-session';
import { redirect } from 'next/navigation';
import { CaseListTable } from '@/widgets/cases/case-list-table';
import { CaseFilters } from '@/features/case-filters';
import { CreateCaseButton } from '@/features/create-case-button';
import { ExportCasesButton } from '@/features/export-cases-button';
import { TableSkeleton } from '@/shared/ui/skeletons/table-skeleton';

export const metadata: Metadata = {
  title: 'Quản Lý Vụ Việc - StarX4CRM',
  description: 'Xem và quản lý tất cả vụ việc pháp lý',
  robots: { index: false, follow: false },
};

interface CasesPageProps {
  searchParams: {
    page?: string;
    search?: string;
    status?: string;
    priority?: string;
    assignee?: string;
    start_date?: string;
    end_date?: string;
    sort_by?: string;
  };
}

// Data fetching function
async function getCasesData(
  userId: string,
  searchParams: CasesPageProps['searchParams']
) {
  const params = new URLSearchParams();

  // Build query params
  const page = searchParams.page || '1';
  const limit = '20';

  params.set('page', page);
  params.set('limit', limit);

  if (searchParams.search) {
    params.set('search', searchParams.search);
  }
  if (searchParams.status) {
    params.set('status', searchParams.status);
  }
  if (searchParams.priority) {
    params.set('priority', searchParams.priority);
  }
  if (searchParams.assignee) {
    params.set('assignee_id', searchParams.assignee);
  }
  if (searchParams.start_date) {
    params.set('start_date', searchParams.start_date);
  }
  if (searchParams.end_date) {
    params.set('end_date', searchParams.end_date);
  }
  if (searchParams.sort_by) {
    params.set('sort_by', searchParams.sort_by);
  }

  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/cases?${params.toString()}`,
    {
      headers: {
        'Authorization': `Bearer ${process.env.INTERNAL_API_TOKEN}`,
        'X-User-ID': userId,
      },
      cache: 'no-store',
      next: { tags: ['cases-list'] },
    }
  );

  if (!res.ok) {
    throw new Error('Failed to fetch cases');
  }

  return res.json();
}

export default async function CasesPage({
  searchParams,
}: CasesPageProps) {
  // Authentication
  const session = await getAuthSession();
  if (!session?.user) {
    redirect('/login?callbackUrl=/cases');
  }

  // Fetch data
  const data = await getCasesData(session.user.id, searchParams);
  const currentPage = parseInt(searchParams.page || '1');
  const totalPages = Math.ceil(data.pagination.total / data.pagination.limit);

  return (
    <div className="min-h-screen bg-gray-50 p-6 space-y-6">
      {/* Header with Title and Actions */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-3xl font-bold text-gray-900">
            Quản Lý Vụ Việc
          </h1>
          <p className="text-gray-600 mt-1">
            Tổng cộng: {data.pagination.total} vụ việc
          </p>
        </div>
        <div className="flex gap-3">
          <ExportCasesButton searchParams={searchParams} />
          <CreateCaseButton />
        </div>
      </div>

      {/* Filters Section */}
      <div className="bg-white rounded-lg shadow-md p-6">
        <h2 className="text-lg font-semibold text-gray-900 mb-4">
          Bộ Lọc
        </h2>
        <CaseFilters currentFilters={searchParams} />
      </div>

      {/* Results Table */}
      <div className="bg-white rounded-lg shadow-md overflow-hidden">
        <Suspense fallback={<TableSkeleton rows={10} />}>
          <CaseListTable
            cases={data.cases}
            pagination={data.pagination}
            searchParams={searchParams}
          />
        </Suspense>
      </div>

      {/* Pagination Info */}
      {totalPages > 1 && (
        <div className="flex items-center justify-between">
          <div className="text-sm text-gray-600">
            Trang {currentPage} của {totalPages}
          </div>
          <div className="flex gap-2">
            {currentPage > 1 && (
              <a
                href={`/cases?page=${currentPage - 1}&${new URLSearchParams(
                  Object.fromEntries(
                    Object.entries(searchParams).filter(
                      ([key]) => key !== 'page'
                    )
                  )
                ).toString()}`}
                className="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700"
              >
                Trang Trước
              </a>
            )}
            {currentPage < totalPages && (
              <a
                href={`/cases?page=${currentPage + 1}&${new URLSearchParams(
                  Object.fromEntries(
                    Object.entries(searchParams).filter(
                      ([key]) => key !== 'page'
                    )
                  )
                ).toString()}`}
                className="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700"
              >
                Trang Sau
              </a>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
```

**URL Structure Examples**:

```
/cases                                    # All cases
/cases?search=hợp+đồng+bán              # Search by title
/cases?status=active                      # Filter by status
/cases?priority=high&page=2              # Combine filters
/cases?start_date=2025-01-01&end_date=2025-01-31  # Date range
/cases?sort_by=created_at_desc           # Sorting
```

**Best Practices**:
- URL-based state for shareable/bookmarkable links
- Server-side filtering for security
- Pagination with total count
- Multiple filter options
- Responsive table layout

