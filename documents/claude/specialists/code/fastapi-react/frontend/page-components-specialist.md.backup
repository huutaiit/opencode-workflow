### Pattern 10.26: Settings/Configuration Page (Form-based)

**Purpose**: User settings with multiple form sections

**File**: `src/app/(dashboard)/settings/page.tsx`

**Complete Implementation**:

```typescript
import { Metadata } from 'next';
import { Suspense } from 'react';
import { redirect } from 'next/navigation';
import { getAuthSession } from '@/shared/auth/get-session';
import { ProfileSettingsForm } from '@/features/settings/profile-settings-form';
import { SecuritySettingsForm } from '@/features/settings/security-settings-form';
import { NotificationSettingsForm } from '@/features/settings/notification-settings-form';
import { PreferencesSettingsForm } from '@/features/settings/preferences-settings-form';
import { DangerZoneForm } from '@/features/settings/danger-zone-form';
import { SettingsSectionCard } from '@/shared/ui/settings-section-card';
import { SettingsSectionSkeleton } from '@/shared/ui/skeletons/settings-section-skeleton';

export const metadata: Metadata = {
  title: 'Cài Đặt - StarX4CRM',
  description: 'Quản lý cài đặt tài khoản của bạn',
  robots: {
    index: false,
    follow: false,
  },
};

async function getCurrentUser(userId: string) {
  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/users/${userId}`,
    {
      headers: {
        'Authorization': `Bearer ${process.env.INTERNAL_API_TOKEN}`,
      },
      cache: 'no-store',
    }
  );

  if (!res.ok) throw new Error('Failed to fetch user');
  return res.json();
}

async function getUserPreferences(userId: string) {
  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/users/${userId}/preferences`,
    {
      headers: {
        'Authorization': `Bearer ${process.env.INTERNAL_API_TOKEN}`,
      },
      cache: 'no-store',
    }
  );

  if (!res.ok) throw new Error('Failed to fetch preferences');
  return res.json();
}

export default async function SettingsPage() {
  // Authentication
  const session = await getAuthSession();
  if (!session?.user) {
    redirect('/login?callbackUrl=/settings');
  }

  // Fetch user data
  const [user, preferences] = await Promise.all([
    getCurrentUser(session.user.id),
    getUserPreferences(session.user.id),
  ]);

  return (
    <div className="min-h-screen bg-gray-50 p-6">
      <div className="max-w-4xl mx-auto space-y-6">
        {/* Page Header */}
        <div className="space-y-2">
          <h1 className="text-3xl font-bold text-gray-900">
            Cài Đặt
          </h1>
          <p className="text-gray-600">
            Quản lý cài đặt tài khoản và sở thích của bạn
          </p>
        </div>

        {/* Profile Settings Section */}
        <Suspense fallback={<SettingsSectionSkeleton />}>
          <SettingsSectionCard
            title="Thông Tin Hồ Sơ"
            description="Cập nhật tên, email và ảnh đại diện của bạn"
          >
            <ProfileSettingsForm user={user} />
          </SettingsSectionCard>
        </Suspense>

        {/* Security Settings Section */}
        <Suspense fallback={<SettingsSectionSkeleton />}>
          <SettingsSectionCard
            title="Bảo Mật"
            description="Quản lý mật khẩu và xác thực hai yếu tố"
          >
            <SecuritySettingsForm userId={session.user.id} />
          </SettingsSectionCard>
        </Suspense>

        {/* Notification Settings Section */}
        <Suspense fallback={<SettingsSectionSkeleton />}>
          <SettingsSectionCard
            title="Thông Báo"
            description="Cấu hình cách bạn nhận thông báo"
          >
            <NotificationSettingsForm
              userId={session.user.id}
              currentSettings={preferences.notifications}
            />
          </SettingsSectionCard>
        </Suspense>

        {/* Preferences Section */}
        <Suspense fallback={<SettingsSectionSkeleton />}>
          <SettingsSectionCard
            title="Sở Thích"
            description="Tùy chỉnh giao diện và hành vi ứng dụng"
          >
            <PreferencesSettingsForm
              userId={session.user.id}
              preferences={preferences}
            />
          </SettingsSectionCard>
        </Suspense>

        {/* Danger Zone Section */}
        <Suspense fallback={<SettingsSectionSkeleton />}>
          <SettingsSectionCard
            title="Vùng Nguy Hiểm"
            description="Các hành động không thể hoàn tác"
            variant="danger"
          >
            <DangerZoneForm userId={session.user.id} />
          </SettingsSectionCard>
        </Suspense>

        {/* Save Indicator */}
        <div className="flex items-center justify-between bg-green-50 border border-green-200 rounded-lg p-4 hidden" id="save-indicator">
          <div className="flex items-center gap-2">
            <svg
              className="w-5 h-5 text-green-600"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fillRule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clipRule="evenodd"
              />
            </svg>
            <p className="text-green-800">Cài đặt đã được lưu</p>
          </div>
        </div>
      </div>
    </div>
  );
}
```

**Settings Form Component** (Client Component):

```typescript
// src/features/settings/profile-settings-form.tsx
'use client';

import { useState } from 'react';
import { useFormStatus } from 'react-dom';
import { updateProfileAction } from '@/app/actions/update-profile';

interface User {
  id: string;
  name: string;
  email: string;
  phone?: string;
  avatar_url?: string;
}

export function ProfileSettingsForm({ user }: { user: User }) {
  const [formData, setFormData] = useState({
    name: user.name,
    email: user.email,
    phone: user.phone || '',
  });

  const { pending } = useFormStatus();

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault();

    const result = await updateProfileAction({
      userId: user.id,
      ...formData,
    });

    if (result.success) {
      // Show success message
      const indicator = document.getElementById('save-indicator');
      if (indicator) {
        indicator.classList.remove('hidden');
        setTimeout(() => {
          indicator.classList.add('hidden');
        }, 3000);
      }
    }
  }

  return (
    <form onSubmit={handleSubmit} className="space-y-6">
      {/* Name Field */}
      <div>
        <label className="block text-sm font-medium text-gray-700">
          Tên Đầy Đủ
        </label>
        <input
          type="text"
          value={formData.name}
          onChange={(e) =>
            setFormData({ ...formData, name: e.target.value })
          }
          className="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-900 placeholder-gray-400 focus:border-blue-600 focus:ring-blue-600"
          required
        />
      </div>

      {/* Email Field */}
      <div>
        <label className="block text-sm font-medium text-gray-700">
          Email
        </label>
        <input
          type="email"
          value={formData.email}
          onChange={(e) =>
            setFormData({ ...formData, email: e.target.value })
          }
          className="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-900 placeholder-gray-400 focus:border-blue-600 focus:ring-blue-600"
          required
        />
      </div>

      {/* Phone Field */}
      <div>
        <label className="block text-sm font-medium text-gray-700">
          Số Điện Thoại
        </label>
        <input
          type="tel"
          value={formData.phone}
          onChange={(e) =>
            setFormData({ ...formData, phone: e.target.value })
          }
          className="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-900 placeholder-gray-400 focus:border-blue-600 focus:ring-blue-600"
          placeholder="+84 (0) 123-456-789"
        />
      </div>

      {/* Submit Button */}
      <button
        type="submit"
        disabled={pending}
        className="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:bg-gray-400 disabled:cursor-not-allowed transition-colors"
      >
        {pending ? 'Đang Lưu...' : 'Lưu Thay Đổi'}
      </button>
    </form>
  );
}
```

**Best Practices**:
- Section-based layout with clear organization
- Suspense for each form section
- Client components for interactive forms
- Visual feedback on save
- Danger zone separated and clearly labeled
- Vietnamese labels for legal domain

