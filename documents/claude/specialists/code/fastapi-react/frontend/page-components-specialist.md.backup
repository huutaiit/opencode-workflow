### Pattern 10.16: Case/User Detail Page (Dynamic Route)

**Purpose**: Individual case/user profile with tabs and related data

**File**: `src/app/(dashboard)/cases/[id]/page.tsx`

**Complete Implementation**:

```typescript
import { Metadata } from 'next';
import { Suspense } from 'react';
import { notFound, redirect } from 'next/navigation';
import { getAuthSession } from '@/shared/auth/get-session';
import { CaseOverview } from '@/widgets/cases/case-overview';
import { CaseDocuments } from '@/widgets/cases/case-documents';
import { CaseTimeline } from '@/widgets/cases/case-timeline';
import { CaseNotes } from '@/widgets/cases/case-notes';
import { CaseClients } from '@/widgets/cases/case-clients';
import { TabNavigation } from '@/shared/ui/tab-navigation';
import { SectionSkeleton } from '@/shared/ui/skeletons/section-skeleton';

interface CaseDetailPageProps {
  params: {
    id: string;
  };
  searchParams: {
    tab?: string;
  };
}

// Fetch case data
async function getCaseData(caseId: string, userId: string) {
  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/cases/${caseId}`,
    {
      headers: {
        'Authorization': `Bearer ${process.env.INTERNAL_API_TOKEN}`,
        'X-User-ID': userId,
      },
      next: { revalidate: 60 },
    }
  );

  if (!res.ok) {
    if (res.status === 404) return null;
    if (res.status === 403) throw new Error('Access denied');
    throw new Error('Failed to fetch case');
  }

  return res.json();
}

// Generate dynamic metadata
export async function generateMetadata({
  params,
}: CaseDetailPageProps): Promise<Metadata> {
  const session = await getAuthSession();
  if (!session?.user) {
    return { title: 'Case Not Found' };
  }

  const caseData = await getCaseData(params.id, session.user.id);

  if (!caseData) {
    return {
      title: 'Vụ Việc Không Tìm Thấy',
    };
  }

  return {
    title: `${caseData.case_number} - ${caseData.title} - StarX4CRM`,
    description: `Chi tiết vụ việc: ${caseData.title}`,
  };
}

// Generate static params for known cases
export async function generateStaticParams() {
  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/cases?limit=100`,
    {
      headers: {
        'Authorization': `Bearer ${process.env.INTERNAL_API_TOKEN}`,
      },
    }
  );

  const data = await res.json();

  return data.cases.map((caseItem: { id: string }) => ({
    id: caseItem.id,
  }));
}

export default async function CaseDetailPage({
  params,
  searchParams,
}: CaseDetailPageProps) {
  // Authentication
  const session = await getAuthSession();
  if (!session?.user) {
    redirect('/login?callbackUrl=/cases/' + params.id);
  }

  // Fetch case data
  const caseData = await getCaseData(params.id, session.user.id);

  if (!caseData) {
    notFound();
  }

  // Tab configuration
  const currentTab = searchParams.tab || 'overview';

  const tabs = [
    {
      id: 'overview',
      label: 'Tổng Quan',
      href: `/cases/${params.id}?tab=overview`,
    },
    {
      id: 'documents',
      label: 'Tài Liệu',
      href: `/cases/${params.id}?tab=documents`,
    },
    {
      id: 'timeline',
      label: 'Dòng Thời Gian',
      href: `/cases/${params.id}?tab=timeline`,
    },
    {
      id: 'notes',
      label: 'Ghi Chú',
      href: `/cases/${params.id}?tab=notes`,
    },
    {
      id: 'clients',
      label: 'Khách Hàng',
      href: `/cases/${params.id}?tab=clients`,
    },
  ];

  return (
    <div className="min-h-screen bg-gray-50 p-6 space-y-6">
      {/* Header */}
      <div className="space-y-2">
        <div className="flex items-start justify-between">
          <div>
            <h1 className="text-4xl font-bold text-gray-900">
              {caseData.case_number}
            </h1>
            <p className="text-xl text-gray-600 mt-1">{caseData.title}</p>
          </div>
          <div className="flex gap-2">
            <span className={`px-3 py-1 rounded-full text-sm font-semibold ${
              caseData.status === 'active'
                ? 'bg-green-100 text-green-800'
                : caseData.status === 'pending'
                ? 'bg-yellow-100 text-yellow-800'
                : 'bg-gray-100 text-gray-800'
            }`}>
              {caseData.status_label}
            </span>
            <span className={`px-3 py-1 rounded-full text-sm font-semibold ${
              caseData.priority === 'high'
                ? 'bg-red-100 text-red-800'
                : caseData.priority === 'medium'
                ? 'bg-orange-100 text-orange-800'
                : 'bg-blue-100 text-blue-800'
            }`}>
              {caseData.priority_label}
            </span>
          </div>
        </div>

        <div className="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
          <div>
            <p className="text-gray-600">Ngày Tạo</p>
            <p className="font-semibold">
              {new Date(caseData.created_at).toLocaleDateString('vi-VN')}
            </p>
          </div>
          <div>
            <p className="text-gray-600">Loại Vụ Việc</p>
            <p className="font-semibold">{caseData.type_label}</p>
          </div>
          <div>
            <p className="text-gray-600">Người Phụ Trách</p>
            <p className="font-semibold">{caseData.assigned_to?.name || 'Chưa gán'}</p>
          </div>
          <div>
            <p className="text-gray-600">Vụ Việc Liên Kết</p>
            <p className="font-semibold">{caseData.related_cases?.length || 0}</p>
          </div>
        </div>
      </div>

      {/* Tab Navigation */}
      <TabNavigation tabs={tabs} currentTab={currentTab} />

      {/* Tab Content */}
      <div className="bg-white rounded-lg shadow-md p-6">
        {currentTab === 'overview' && (
          <Suspense fallback={<SectionSkeleton />}>
            <CaseOverview case={caseData} />
          </Suspense>
        )}

        {currentTab === 'documents' && (
          <Suspense fallback={<SectionSkeleton />}>
            <CaseDocuments caseId={params.id} />
          </Suspense>
        )}

        {currentTab === 'timeline' && (
          <Suspense fallback={<SectionSkeleton />}>
            <CaseTimeline caseId={params.id} />
          </Suspense>
        )}

        {currentTab === 'notes' && (
          <Suspense fallback={<SectionSkeleton />}>
            <CaseNotes caseId={params.id} />
          </Suspense>
        )}

        {currentTab === 'clients' && (
          <Suspense fallback={<SectionSkeleton />}>
            <CaseClients caseId={params.id} />
          </Suspense>
        )}
      </div>
    </div>
  );
}
```

**Route Examples**:

```
/cases/case-001                     # Overview tab
/cases/case-001?tab=documents       # Documents tab
/cases/case-001?tab=timeline        # Timeline tab
/cases/case-001?tab=notes           # Notes tab
/cases/case-001?tab=clients         # Clients tab
```

**Best Practices**:
- Dynamic metadata generation
- Static generation for known routes
- Tab-based navigation with URL state
- Status and priority badges with colors
- Granular permission checks

