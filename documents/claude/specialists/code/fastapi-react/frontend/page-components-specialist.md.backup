### Pattern 10.21: Conversation/Message Detail Page (Streaming)

**Purpose**: Real-time messaging with streaming and progressive loading

**File**: `src/app/(dashboard)/conversations/[id]/page.tsx`

**Complete Implementation**:

```typescript
import { Metadata } from 'next';
import { Suspense } from 'react';
import { notFound, redirect } from 'next/navigation';
import { getAuthSession } from '@/shared/auth/get-session';
import { ConversationHeader } from '@/widgets/conversations/conversation-header';
import { MessageList } from '@/widgets/conversations/message-list';
import { MessageInput } from '@/features/message-input';
import { ConversationInfo } from '@/widgets/conversations/conversation-info';
import { MessageListSkeleton } from '@/shared/ui/skeletons/message-list-skeleton';

interface ConversationPageProps {
  params: {
    id: string;
  };
  searchParams: {
    search?: string;
  };
}

async function getConversationData(conversationId: string, userId: string) {
  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/api/conversations/${conversationId}`,
    {
      headers: {
        'Authorization': `Bearer ${process.env.INTERNAL_API_TOKEN}`,
        'X-User-ID': userId,
      },
      cache: 'no-store',
    }
  );

  if (!res.ok) {
    if (res.status === 404) return null;
    if (res.status === 403) throw new Error('Access denied');
    throw new Error('Failed to fetch conversation');
  }

  return res.json();
}

export async function generateMetadata({
  params,
}: ConversationPageProps): Promise<Metadata> {
  const session = await getAuthSession();
  if (!session?.user) {
    return { title: 'Conversation Not Found' };
  }

  const conversation = await getConversationData(
    params.id,
    session.user.id
  );

  if (!conversation) {
    return {
      title: 'Cuộc Trò Chuyện Không Tìm Thấy',
    };
  }

  return {
    title: `${conversation.title || 'Cuộc Trò Chuyện'} - StarX4CRM`,
    description: 'Xem tin nhắn và thảo luận',
    robots: {
      index: false,
      follow: false,
    },
  };
}

export default async function ConversationPage({
  params,
  searchParams,
}: ConversationPageProps) {
  // Authentication
  const session = await getAuthSession();
  if (!session?.user) {
    redirect(
      `/login?callbackUrl=/conversations/${params.id}`
    );
  }

  // Fetch conversation
  const conversation = await getConversationData(
    params.id,
    session.user.id
  );

  if (!conversation) {
    notFound();
  }

  return (
    <div className="flex h-[calc(100vh-64px)] bg-gray-50">
      {/* Main Conversation Area */}
      <div className="flex-1 flex flex-col bg-white border-r border-gray-200">
        {/* Header */}
        <div className="border-b border-gray-200 p-4 bg-white shadow-sm">
          <ConversationHeader
            conversation={conversation}
            currentUserId={session.user.id}
          />
        </div>

        {/* Messages Area */}
        <div className="flex-1 overflow-y-auto p-6 space-y-4">
          <Suspense fallback={<MessageListSkeleton />}>
            <MessageList
              conversationId={params.id}
              userId={session.user.id}
              searchQuery={searchParams.search}
            />
          </Suspense>
        </div>

        {/* Message Input */}
        <div className="border-t border-gray-200 p-4 bg-white">
          <MessageInput
            conversationId={params.id}
            userId={session.user.id}
          />
        </div>
      </div>

      {/* Conversation Info Sidebar */}
      <div className="w-80 bg-gray-50 border-l border-gray-200 overflow-y-auto">
        <Suspense fallback={<div className="p-4 animate-pulse" />}>
          <ConversationInfo
            conversation={conversation}
            userId={session.user.id}
          />
        </Suspense>
      </div>
    </div>
  );
}
```

**Client Component for Message Streaming**:

```typescript
// src/widgets/conversations/message-list.tsx
'use client';

import { useEffect, useRef, useCallback } from 'react';
import { useQuery } from '@tanstack/react-query';
import { MessageBubble } from './message-bubble';
import { MessageListSkeleton } from '@/shared/ui/skeletons/message-list-skeleton';

interface Message {
  id: string;
  content: string;
  sender_id: string;
  created_at: string;
  attachments?: Array<{ id: string; url: string; name: string }>;
}

export function MessageList({
  conversationId,
  userId,
  searchQuery,
}: {
  conversationId: string;
  userId: string;
  searchQuery?: string;
}) {
  const messagesEndRef = useRef<HTMLDivElement>(null);

  // Fetch messages with polling for real-time updates
  const { data, isLoading, refetch } = useQuery({
    queryKey: ['messages', conversationId, searchQuery],
    queryFn: async () => {
      const params = new URLSearchParams();
      if (searchQuery) params.set('search', searchQuery);

      const res = await fetch(
        `/api/conversations/${conversationId}/messages?${params.toString()}`
      );
      if (!res.ok) throw new Error('Failed to fetch messages');
      return res.json();
    },
    refetchInterval: 3000, // Poll every 3 seconds
    staleTime: 2000, // Consider data stale after 2 seconds
  });

  // Auto-scroll to bottom on new messages
  const scrollToBottom = useCallback(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, []);

  useEffect(() => {
    scrollToBottom();
  }, [data?.messages, scrollToBottom]);

  if (isLoading) return <MessageListSkeleton />;

  return (
    <div className="space-y-4">
      {data?.messages.map((message: Message) => (
        <MessageBubble
          key={message.id}
          message={message}
          isOwn={message.sender_id === userId}
        />
      ))}
      <div ref={messagesEndRef} />
    </div>
  );
}
```

**Best Practices**:
- Split layout (message list + sidebar info)
- Real-time polling with React Query
- Auto-scroll to latest message
- Search within conversation
- Suspense for message loading
- Responsive layout

