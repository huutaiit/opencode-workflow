## III. TECHNOLOGY STACK DETAILS

### Next.js 15.3.0 App Router Features Used

```typescript
// 1. Server Components (Default)
export default async function Page() {
  const data = await fetch(...);
  return <div>{data}</div>;
}

// 2. Client Components
'use client';
export function InteractiveComponent() {
  const [state, setState] = useState();
  return <button onClick={() => setState(...)}>Click</button>;
}

// 3. Metadata API
export const metadata: Metadata = {
  title: 'Page Title',
  description: 'Page description',
};

export async function generateMetadata(): Promise<Metadata> {
  const data = await fetch(...);
  return {
    title: data.title,
  };
}

// 4. Dynamic Routes
// File: app/items/[id]/page.tsx
export async function generateStaticParams() {
  return [{ id: '1' }, { id: '2' }];
}

// 5. Route Groups
// Folder: app/(dashboard)/
// Folder: app/(auth)/
// Groups are not included in URL path

// 6. Search Params
interface PageProps {
  searchParams: {
    [key: string]: string | string[] | undefined;
  };
}

// 7. Suspense & Streaming
<Suspense fallback={<Loading />}>
  <AsyncComponent />
</Suspense>
```

### React 19 Features Used

```typescript
// 1. Server Components
async function ServerComponent() {
  const data = await fetchData();
  return <div>{data}</div>;
}

// 2. Suspense
<Suspense fallback={<Skeleton />}>
  <AsyncContent />
</Suspense>

// 3. use() Hook
'use client';
import { use } from 'react';

function Component({ promise }: { promise: Promise<Data> }) {
  const data = use(promise);
  return <div>{data}</div>;
}

// 4. useActionState (formerly useFormState)
'use client';
import { useActionState } from 'react';

function Form() {
  const [state, formAction] = useActionState(serverAction, null);
  return <form action={formAction}>...</form>;
}

// 5. useOptimistic
'use client';
import { useOptimistic } from 'react';

function TodoList({ todos }: { todos: Todo[] }) {
  const [optimistic, addOptimistic] = useOptimistic(todos);
  // Optimistic updates
}
```

### TypeScript 5 Strict Mode

```typescript
// All code uses strict type checking
// No `any` types allowed
// Full generic support
// Const type parameters

interface ApiResponse<T> {
  data: T;
  status: number;
  message: string;
}

async function fetchData<T>(
  url: string
): Promise<ApiResponse<T>> {
  const res = await fetch(url);
  return res.json();
}

const data = await fetchData<CaseData>('/api/cases/123');
// data.data is properly typed as CaseData
```

