        ],
        "animation": [
          "react-motion",
          "react-css-transitions"
        ],
        "layout": [
          "react-layout-patterns",
          "react-skeleton-loading"
        ],
        "features": [
          "react-rich-text-editor",
          "react-antd-charts"
        ],
        "dnd": [
          "react-drag-drop"
        ],
        "styling": [
          "react-antd-tokens-styling"
        ],
        "pwa": [
          "react-pwa"
        ]
      },
      "specialistDir": "reactjs-fsd",
      "kb_path": {
        "frontend": ".claude/utils/knowledge-base/frontend-kb-react.json"
      }
    }
  }
}
