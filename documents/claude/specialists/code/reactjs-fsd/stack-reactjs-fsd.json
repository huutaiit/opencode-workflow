          "react-feature-flags"
        ],
        "testing": [
          "react-unit-testing",
          "react-integration-testing",
          "react-e2e-testing",
          "react-storybook"
        ],
        "devops": [
          "react-vite-build",
          "react-docker",
          "react-cicd"
        ],
        "domain": [
          "react-domain-models",
          "react-validation-schemas",
          "react-domain-events"
        ],
        "localization": [
          "react-i18n",
