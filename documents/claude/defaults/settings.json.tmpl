{
  "permissions": {
    "allow": [
      "Read", "Glob", "Grep", "WebFetch", "WebSearch",
      "Bash(node .claude/*)",
      "Bash(git *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          { "type": "command", "command": "node .claude/guards/hooks/workflow-gate.js", "timeout": 10 },
          { "type": "command", "command": "node .claude/guards/hooks/architecture-awareness.js", "timeout": 10 }
        ]
      },
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          { "type": "command", "command": "node .claude/guards/hooks/commit-guard.js", "timeout": 5 }
        ]
      }
    ],
    "Stop": [],
    "PreCompact": [],
    "UserPromptSubmit": []
  },
  "preserved-state": {},
  "ops": {
    "output_file": ".claude/cache/ops-result.json",
    "cache_dir": ".claude/cache/"
  }
}
