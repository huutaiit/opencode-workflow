{
  "$comment": "Python FastAPI stack",
  "name": "Python FastAPI",
  "language": "python",
  "framework": "fastapi",
  "version": { "python": "3.13+", "fastapi": "0.115+" },
  "extensions": [".py"],
  "parsing": {
    "parser": "python-parser",
    "extractor": "fastapi-extractor",
    "patterns": {
      "router": { "decorators": ["@router", "@app"], "nameSuffix": ["router", "api"], "nodeType": "Controller" },
      "service": { "nameSuffix": ["service", "handler", "manager"], "nodeType": "Service" },
      "repository": { "nameSuffix": ["repository", "repo", "dao"], "nodeType": "Repository" },
      "model": { "baseClasses": ["BaseModel", "Base"], "nameSuffix": ["model", "schema"], "nodeType": "Entity" }
    }
  },
  "architecture": {
    "supportedArchitectures": ["layered", "clean-architecture", "modular"],
    "defaultArchitecture": null,
    "autoDetection": {
      "layered": { "requiredDirs": ["routers", "services", "models"], "alternativeDirs": ["api", "core", "db"], "confidence": 0.75 },
      "clean-architecture": { "requiredDirs": ["domain", "application", "infrastructure", "presentation"], "confidence": 0.85 },
      "modular": { "pattern": "app/{module_name}/{routers,services,models}", "confidence": 0.8 }
    },
    "layerMappings": {
      "layered": {
        "routers": { "pathPatterns": ["**/routers/**", "**/api/**"], "decorators": ["@router", "@app"], "stereotype": "Router" },
        "services": { "pathPatterns": ["**/services/**", "**/core/**"], "stereotype": "Service" },
        "models": { "pathPatterns": ["**/models/**", "**/schemas/**"], "baseClasses": ["BaseModel", "Base"], "stereotype": "Model" },
        "repositories": { "pathPatterns": ["**/repositories/**", "**/db/**"], "stereotype": "Repository" }
      }
    },
    "databasePatterns": {
      "sqlalchemy": {
        "detection": { "imports": ["sqlalchemy"], "baseClasses": ["Base", "DeclarativeBase"] },
        "technology": "SQLAlchemy", "reactive": false
      },
      "tortoise": {
        "detection": { "imports": ["tortoise"], "baseClasses": ["Model"] },
        "technology": "Tortoise ORM", "reactive": true
      }
    }
  },
  "variants": {
    "default": {
      "name": "FastAPI AI Stack",
      "description": "Full-stack AI platform with LLM/VLM providers, graph DB, vector DB, and RAG",
      "patterns": {
        "use_fastapi": true, "use_pydantic_v2": true, "use_sqlalchemy": true,
        "use_neo4j": true, "use_qdrant": true, "use_redis": true,
        "use_langchain": true, "use_langgraph": true,
        "use_openai": true, "use_anthropic": true, "use_websocket": true
      },
      "specialists": {
        "core": ["fastapi-router-specialist", "pydantic-schemas-specialist", "fastapi-base-repository", "fastapi-postgres-repository", "fastapi-neo4j-repository", "fastapi-qdrant-repository", "fastapi-redis-uow", "websocket-middleware-specialist"],
        "ai": ["llm-providers-specialist", "llm-base-providers", "llm-api-providers", "llm-context-utils", "llm-streaming-utils", "vlm-providers-specialist", "vlm-base-provider", "vlm-api-providers", "vlm-utilities-specialist", "vlm-factory-preprocessing", "vlm-vision-tasks", "embeddings-providers-specialist", "embeddings-batch-specialist", "voice-stt-specialist", "voice-tts-specialist", "llm-vlm-specialist", "voice-services-specialist"],
        "agents": ["langgraph-builder-specialist", "orchestrator-specialist", "expert-agents-specialist"],
        "services": ["storage-specialist", "support-session-cache-specialist", "support-knowledge-storage-specialist", "core-services-specialist", "core-validation-specialist", "core-string-specialist", "core-datetime-specialist", "core-crypto-specialist", "core-http-logging-specialist"],
        "testing": ["e2e-testing-specialist", "api-integration-specialist"]
      },
      "specialistDir": "fastapi-react",
      "kb_path": {
        "backend": ".claude/utils/knowledge-base/backend-kb-fastapi.json",
        "database": ".claude/utils/knowledge-base/database-kb-multi.json"
      }
    }
  },

  "qualityRules": {
    "linter": "ruff",
    "typecheck": "mypy",
    "critical": ["no-hardcoded-ips", "ruff"],
    "warning": ["naming-convention", "comment-style"]
  }
}
