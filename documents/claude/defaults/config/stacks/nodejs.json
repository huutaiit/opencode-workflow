{
  "$comment": "Node.js CommonJS stack — for EPS Framework and similar CLI/tooling projects",
  "name": "Node.js",
  "language": "javascript",
  "framework": "nodejs",
  "version": { "node": "20.x", "javascript": "ES2022" },
  "extensions": [".js", ".mjs", ".cjs"],
  "parsing": {
    "parser": "javascript-parser",
    "patterns": {
      "module": { "exports": ["module.exports", "exports."], "nameSuffix": [], "nodeType": "Module" },
      "class": { "keywords": ["class"], "nameSuffix": [], "nodeType": "Class" },
      "function": { "keywords": ["function", "async function"], "nameSuffix": [], "nodeType": "Function" }
    },
    "moduleSystem": {
      "import": ["require("],
      "export": ["module.exports", "exports."]
    }
  },
  "architecture": {
    "supportedArchitectures": ["layered", "modular", "cli-tooling"],
    "defaultArchitecture": null,
    "autoDetection": {
      "layered": { "requiredDirs": ["core", "lib", "utils"], "confidence": 0.7 },
      "cli-tooling": { "requiredDirs": ["commands", "core", "config"], "indicators": ["bin/", "cli.js"], "confidence": 0.85 }
    },
    "layerMappings": {
      "cli-tooling": {
        "command": { "pathPatterns": ["commands/**/*.md", "commands/**/*.js"], "stereotype": "Command" },
        "core": { "pathPatterns": ["core/**/*.js"], "stereotype": "Engine" },
        "config": { "pathPatterns": ["config/**/*.json"], "stereotype": "Config" },
        "specialist": { "pathPatterns": ["specialists/**/*.md"], "stereotype": "Specialist" }
      }
    }
  },
  "variants": {
    "commonjs": {
      "name": "CommonJS CLI/Tooling",
      "description": "Node.js CommonJS for CLI tools, build systems, and framework engines",
      "patterns": {
        "use_commonjs": true,
        "use_classes": true,
        "use_async_await": true,
        "use_fs": true,
        "use_path": true,
        "use_child_process": true
      },
      "specialists": {
        "core": []
      },
      "specialistDir": "nodejs",
      "kb_path": {}
    }
  },

  "qualityRules": {
    "linter": "eslint",
    "typecheck": null,
    "critical": ["no-duplicate-api", "no-hardcoded-ips", "eslint-zero-warnings", "npm-audit-critical"],
    "warning": ["naming-convention", "comment-style", "import-order"]
  }
}
