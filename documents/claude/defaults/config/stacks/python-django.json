{
  "$comment": "Python Django stack",
  "name": "Python Django",
  "language": "python",
  "framework": "django",
  "version": { "python": "3.13+", "django": "5.x" },
  "extensions": [".py"],
  "parsing": {
    "parser": "python-parser",
    "extractor": "django-extractor",
    "patterns": {
      "model": { "files": ["models.py"], "baseClasses": ["Model"], "nodeType": "Entity" },
      "view": { "files": ["views.py"], "baseClasses": ["View", "APIView"], "nodeType": "Controller" },
      "serializer": { "files": ["serializers.py"], "baseClasses": ["Serializer", "ModelSerializer"], "nodeType": "Class" },
      "url": { "files": ["urls.py"], "nodeType": "Component" },
      "admin": { "files": ["admin.py"], "baseClasses": ["ModelAdmin"], "nodeType": "Component" },
      "form": { "files": ["forms.py"], "baseClasses": ["Form", "ModelForm"], "nodeType": "Component" }
    }
  },
  "architecture": {
    "supportedArchitectures": ["mtv", "clean-architecture", "modular"],
    "defaultArchitecture": null,
    "autoDetection": {
      "mtv": { "requiredFiles": ["models.py", "views.py", "urls.py"], "requiredDirs": ["templates"], "confidence": 0.9 }
    },
    "layerMappings": {
      "mtv": {
        "model": { "files": ["models.py"], "baseClasses": ["Model"], "stereotype": "Model" },
        "template": { "pathPatterns": ["**/templates/**"], "extensions": [".html"], "stereotype": "Template" },
        "view": { "files": ["views.py"], "baseClasses": ["View", "APIView"], "stereotype": "View" }
      }
    },
    "databasePatterns": {
      "django-orm": {
        "detection": { "imports": ["django.db.models"], "baseClasses": ["Model"] },
        "technology": "Django ORM", "reactive": false
      }
    }
  },
