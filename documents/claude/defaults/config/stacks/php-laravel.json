{
  "$comment": "PHP Laravel stack",
  "name": "PHP Laravel",
  "language": "php",
  "framework": "laravel",
  "version": { "php": "8.2+", "laravel": "10.x" },
  "extensions": [".php"],
  "parsing": {
    "parser": "php-parser",
    "extractor": "laravel-extractor",
    "patterns": {
      "controller": { "nameSuffix": ["Controller"], "baseClasses": ["Controller"], "directory": "app/Http/Controllers", "nodeType": "Controller" },
      "model": { "baseClasses": ["Model", "Authenticatable", "Pivot"], "traits": ["HasFactory", "SoftDeletes", "Notifiable"], "directory": "app/Models", "nodeType": "Entity" },
      "service": { "nameSuffix": ["Service", "Handler"], "directory": "app/Services", "nodeType": "Service" },
      "repository": { "nameSuffix": ["Repository", "Repo"], "directory": "app/Repositories", "nodeType": "Repository" },
      "middleware": { "nameSuffix": ["Middleware"], "interfaces": ["Middleware"], "directory": "app/Http/Middleware", "nodeType": "Component" },
      "request": { "nameSuffix": ["Request"], "baseClasses": ["FormRequest"], "directory": "app/Http/Requests", "nodeType": "Component" },
      "resource": { "nameSuffix": ["Resource", "Collection"], "baseClasses": ["JsonResource", "ResourceCollection"], "directory": "app/Http/Resources", "nodeType": "Component" },
      "job": { "nameSuffix": ["Job"], "interfaces": ["ShouldQueue"], "directory": "app/Jobs", "nodeType": "Component" },
      "event": { "nameSuffix": ["Event"], "directory": "app/Events", "nodeType": "Component" },
      "listener": { "nameSuffix": ["Listener"], "directory": "app/Listeners", "nodeType": "Component" },
      "policy": { "nameSuffix": ["Policy"], "directory": "app/Policies", "nodeType": "Component" },
      "provider": { "nameSuffix": ["ServiceProvider"], "baseClasses": ["ServiceProvider"], "directory": "app/Providers", "nodeType": "Component" }
    },
    "attributes": {
      "php8": ["Route", "Middleware", "Controller"],
      "validation": ["Required", "String", "Integer", "Email", "Unique", "Exists"]
    },
    "directories": {
      "controllers": "app/Http/Controllers", "models": "app/Models",
      "services": "app/Services", "repositories": "app/Repositories",
      "middleware": "app/Http/Middleware", "requests": "app/Http/Requests",
      "resources": "app/Http/Resources", "jobs": "app/Jobs",
      "events": "app/Events", "listeners": "app/Listeners",
      "policies": "app/Policies", "providers": "app/Providers",
      "routes": "routes"
    },
    "eloquentRelationships": [
      "hasOne", "hasMany", "belongsTo", "belongsToMany",
      "hasManyThrough", "hasOneThrough", "morphTo", "morphOne",
      "morphMany", "morphToMany", "morphedByMany"
    ]
  },
  "architecture": {
    "supportedArchitectures": ["mvc", "clean-architecture", "modular-monolith", "ddd"],
    "defaultArchitecture": null,
    "autoDetection": {
      "mvc": { "requiredDirs": ["app/Http/Controllers", "app/Models", "resources/views"], "confidence": 0.8 },
      "clean-architecture": { "requiredDirs": ["app/Domain", "app/Application", "app/Infrastructure"], "alternativeDirs": ["src/Domain", "src/Application"], "confidence": 0.85 },
      "modular-monolith": { "requiredPattern": "Modules/*", "confidence": 0.85 },
      "ddd": { "requiredDirs": ["Domain", "Application", "Infrastructure"], "indicators": ["AggregateRoot", "ValueObject", "DomainEvent"], "confidence": 0.85 }
    },
    "layerMappings": {
      "mvc": {
        "model": { "pathPatterns": ["app/Models/**"], "baseClasses": ["Model", "Authenticatable"], "stereotype": "Model" },
        "view": { "pathPatterns": ["resources/views/**"], "extensions": [".blade.php"], "stereotype": "View" },
        "controller": { "pathPatterns": ["app/Http/Controllers/**"], "baseClasses": ["Controller"], "stereotype": "Controller" }
      },
      "clean-architecture": {
        "domain": { "pathPatterns": ["app/Domain/**", "app/Models/**"], "baseClasses": ["Model"], "stereotype": "DomainEntity" },
        "application": { "pathPatterns": ["app/Services/**", "app/Actions/**", "app/Jobs/**"], "nameSuffix": ["Service", "Action", "Job"], "stereotype": "ApplicationService" },
        "infrastructure": { "pathPatterns": ["app/Repositories/**", "app/Providers/**"], "baseClasses": ["ServiceProvider"], "stereotype": "InfrastructureAdapter" },
        "presentation": { "pathPatterns": ["app/Http/Controllers/**", "app/Http/Requests/**"], "baseClasses": ["Controller", "FormRequest"], "stereotype": "PresentationController" }
      }
    },
    "databasePatterns": {
      "eloquent": {
        "detection": { "baseClasses": ["Model"], "traits": ["HasFactory", "SoftDeletes"] },
        "technology": "Eloquent ORM", "pattern": "Active Record", "reactive": false
      },
      "query-builder": {
        "detection": { "facades": ["DB"], "methods": ["table", "select", "where"] },
        "technology": "Laravel Query Builder", "reactive": false
      }
    }
  },
  "variants": {},

  "qualityRules": {
    "linter": "phpstan",
    "typecheck": null,
    "critical": ["no-hardcoded-ips", "no-hardcoded-strings"],
    "warning": ["naming-convention", "comment-style"]
  }
}
