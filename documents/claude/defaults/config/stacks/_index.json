{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Stack registry — lightweight index for lazy loading per-stack files",
  "version": "3.0.0",
  "updated": "2026-03-01",

  "stacks": {
    "java-spring-boot": {
      "name": "Java Spring Boot",
      "language": "java",
      "framework": "spring-boot",
      "file": "java-spring-boot.json"
    },
    "typescript-nextjs": {
      "name": "TypeScript Next.js",
      "language": "typescript",
      "framework": "nextjs",
      "file": "typescript-nextjs.json"
    },
    "typescript-nestjs": {
      "name": "TypeScript NestJS",
      "language": "typescript",
      "framework": "nestjs",
      "file": "typescript-nestjs.json"
    },
    "typescript-react": {
      "name": "TypeScript React",
      "language": "typescript",
      "framework": "react",
      "file": "typescript-react.json"
    },
    "csharp-dotnet-core": {
      "name": "C# .NET Core",
      "language": "csharp",
      "framework": "dotnet-core",
      "file": "csharp-dotnet-core.json"
    },
    "php-laravel": {
      "name": "PHP Laravel",
      "language": "php",
      "framework": "laravel",
      "file": "php-laravel.json"
    },
    "python-fastapi": {
      "name": "Python FastAPI",
      "language": "python",
      "framework": "fastapi",
      "file": "python-fastapi.json"
    },
    "python-django": {
      "name": "Python Django",
      "language": "python",
      "framework": "django",
      "file": "python-django.json"
    },
    "nodejs": {
      "name": "Node.js",
      "language": "javascript",
      "framework": "nodejs",
      "file": "nodejs.json"
    },
    "flutter-dart": {
      "name": "Flutter/Dart",
      "language": "dart",
      "framework": "flutter",
      "file": "flutter-dart.json"
    }
  },

  "extensionToLanguage": {
    ".java": "java",
    ".ts": "typescript",
    ".tsx": "typescript",
    ".js": "javascript",
    ".jsx": "javascript",
    ".kt": "kotlin",
    ".kts": "kotlin",
    ".py": "python",
    ".go": "go",
    ".rs": "rust",
    ".cs": "csharp",
    ".php": "php",
    ".dart": "dart"
  },

  "languageToStacks": {
    "java": ["java-spring-boot"],
    "typescript": ["typescript-nextjs", "typescript-nestjs", "typescript-react"],
    "javascript": ["nodejs", "typescript-nextjs", "typescript-react"],
    "csharp": ["csharp-dotnet-core"],
    "php": ["php-laravel"],
    "python": ["python-fastapi", "python-django"],
    "dart": ["flutter-dart"]
  },

  "excludePatterns": [
    "node_modules", "dist", "target", "build",
    ".git", ".idea", ".next", "coverage",
    "__pycache__", "*.test.*", "*.spec.*", "*.d.ts",
    "bin", "obj", "vendor", "storage", "bootstrap/cache"
  ],

  "priorityPatterns": {
    "high": ["*Controller*", "*Service*", "*Repository*", "*Resource*", "page.tsx", "route.ts"],
    "medium": ["*Entity*", "*DTO*", "*Mapper*", "layout.tsx", "*Hook*"],
    "low": ["*Config*", "*Util*", "*Helper*", "*Constant*"]
  }
}
