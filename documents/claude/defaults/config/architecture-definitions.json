          },
          "controller": {
            "pathPatterns": ["app/Http/Controllers/**"],
            "baseClasses": ["Controller"],
            "stereotype": "Controller"
          }
        },
        "clean-architecture": {
          "domain": {
            "pathPatterns": ["app/Domain/**", "app/Models/**"],
            "baseClasses": ["Model"],
            "stereotype": "DomainEntity"
          },
          "application": {
            "pathPatterns": ["app/Services/**", "app/Actions/**", "app/Jobs/**"],
            "nameSuffix": ["Service", "Action", "Job"],
            "stereotype": "ApplicationService"
          },
          "infrastructure": {
            "pathPatterns": ["app/Repositories/**", "app/Providers/**"],
            "baseClasses": ["ServiceProvider"],
