            "stereotype": "Router"
          },
          "services": {
            "pathPatterns": ["**/services/**", "**/core/**"],
            "stereotype": "Service"
          },
          "models": {
            "pathPatterns": ["**/models/**", "**/schemas/**"],
            "baseClasses": ["BaseModel", "Base"],
            "stereotype": "Model"
          },
          "repositories": {
            "pathPatterns": ["**/repositories/**", "**/db/**"],
            "stereotype": "Repository"
          }
        }
      },
      "databasePatterns": {
        "sqlalchemy": {
          "detection": {
            "imports": ["sqlalchemy"],
            "baseClasses": ["Base", "DeclarativeBase"]
          },
          "technology": "SQLAlchemy",
          "reactive": false
        },
        "tortoise": {
          "detection": {
            "imports": ["tortoise"],
            "baseClasses": ["Model"]
          },
          "technology": "Tortoise ORM",
          "reactive": true
        }
      }
    },

    "python-django": {
      "name": "Python Django",
      "supportedArchitectures": ["mtv", "clean-architecture", "modular"],
      "defaultArchitecture": null,
      "autoDetection": {
        "mtv": {
          "requiredFiles": ["models.py", "views.py", "urls.py"],
          "requiredDirs": ["templates"],
          "confidence": 0.9
        }
      },
      "layerMappings": {
        "mtv": {
          "model": {
            "files": ["models.py"],
            "baseClasses": ["Model"],
            "stereotype": "Model"
          },
          "template": {
            "pathPatterns": ["**/templates/**"],
            "extensions": [".html"],
            "stereotype": "Template"
          },
          "view": {
            "files": ["views.py"],
            "baseClasses": ["View", "APIView"],
            "stereotype": "View"
          }
        }
      },
      "databasePatterns": {
        "django-orm": {
          "detection": {
            "imports": ["django.db.models"],
            "baseClasses": ["Model"]
          },
          "technology": "Django ORM",
          "reactive": false
        }
      }
    }
  },

  "detectionStrategy": {
    "order": [
      "projectConfig",
      "directoryStructure",
      "filePatterns",
      "markers",
      "imports"
    ],
    "fallback": "layered",
    "confidenceThreshold": 0.7,
    "multipleArchitectureSupport": true,
    "notes": [
      "If project-config.json specifies architecture, use that",
      "Otherwise, auto-detect based on directory structure",
      "If confidence < threshold, ask user for clarification",
      "Some projects may use different architectures in different modules"
    ]
  },

